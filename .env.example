# DataForge — Environment Configuration
# Copy to .env and fill in your values.
#
# The YAML path (dataforge generate --from data-product.yaml) needs ZERO configuration.
# Only the NL path (dataforge generate "...") needs an LLM provider + API key.

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Pick one. Default is anthropic.
DATAFORGE_LLM_PROVIDER=anthropic
# anthropic | openai | groq | ollama | mistral | together | azure_openai

# ── Option 1: Anthropic (default) ─────────────────────────────────────────────
DATAFORGE_ANTHROPIC_API_KEY=sk-ant-...
# DATAFORGE_PARSE_MODEL=claude-haiku-4-5-20251001
# DATAFORGE_GENERATE_MODEL=claude-sonnet-4-6

# ── Option 2: OpenAI ──────────────────────────────────────────────────────────
# pip install 'dataforge[openai]'
# DATAFORGE_LLM_PROVIDER=openai
# DATAFORGE_OPENAI_API_KEY=sk-...
# DATAFORGE_OPENAI_PARSE_MODEL=gpt-4o
# DATAFORGE_OPENAI_GENERATE_MODEL=gpt-4o

# ── Option 3: Groq (fast inference, free tier available) ──────────────────────
# pip install 'dataforge[openai]'
# DATAFORGE_LLM_PROVIDER=groq
# DATAFORGE_OPENAI_API_KEY=gsk_...
# DATAFORGE_OPENAI_BASE_URL=https://api.groq.com/openai/v1
# DATAFORGE_OPENAI_PARSE_MODEL=llama-3.3-70b-versatile
# DATAFORGE_OPENAI_GENERATE_MODEL=llama-3.3-70b-versatile

# ── Option 4: Ollama (local, no API key needed) ───────────────────────────────
# pip install 'dataforge[openai]'
# DATAFORGE_LLM_PROVIDER=ollama
# DATAFORGE_OPENAI_API_KEY=ollama          # any non-empty string
# DATAFORGE_OPENAI_BASE_URL=http://localhost:11434/v1
# DATAFORGE_OPENAI_PARSE_MODEL=llama3.2
# DATAFORGE_OPENAI_GENERATE_MODEL=llama3.2

# ── Option 5: Mistral AI ──────────────────────────────────────────────────────
# pip install 'dataforge[openai]'
# DATAFORGE_LLM_PROVIDER=mistral
# DATAFORGE_OPENAI_API_KEY=<mistral-key>
# DATAFORGE_OPENAI_BASE_URL=https://api.mistral.ai/v1
# DATAFORGE_OPENAI_PARSE_MODEL=mistral-large-latest
# DATAFORGE_OPENAI_GENERATE_MODEL=mistral-large-latest

# ── Option 6: Azure OpenAI ────────────────────────────────────────────────────
# pip install 'dataforge[openai]'
# DATAFORGE_LLM_PROVIDER=azure_openai
# DATAFORGE_OPENAI_API_KEY=<your-azure-openai-key>
# DATAFORGE_OPENAI_BASE_URL=https://<your-resource>.openai.azure.com/
# DATAFORGE_OPENAI_PARSE_MODEL=gpt-4o
# DATAFORGE_OPENAI_GENERATE_MODEL=gpt-4o

# ── Optional: Output directory ────────────────────────────────────────────────
# DATAFORGE_OUTPUT_DIR=./output
