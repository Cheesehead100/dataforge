{#
  drift/drift_notify.py.j2 — Python script that parses terraform plan output and
  dispatches drift notifications to configured channels.
  Parses: adds/changes/destroys/replaces counts and changed resource names from
  terraform plan -detailed-exitcode stdout; classifies severity (none/warning/critical).
  Notification channels: always writes a JSON report; conditionally includes
  Teams (Adaptive Card) and Slack (Block Kit) webhook functions.
  Context vars: product_name, env, notification (has_teams, has_slack,
  teams_webhook_secret, slack_webhook_secret, email).
  Env logic: none — channel availability is controlled by notification flags.
  Constraint: Exits with code 1 on drift or error so the CI/CD pipeline fails.
#}
#!/usr/bin/env python3
"""
DataForge Drift Notification Parser — {{ product_name }}
Generated by DataForge DriftDetectionGenerator (L8)

Parses `terraform plan -detailed-exitcode` output and produces a structured
drift report. Called by the drift detection CI/CD workflow.

Notification channels configured for this product:
  - GitHub Actions job summary (always enabled)
{% if notification.has_email %}  - Email → {{ notification.email }}
{% endif %}{% if notification.has_teams %}  - Microsoft Teams (webhook URL in secret {{ notification.teams_webhook_secret }})
{% endif %}{% if notification.has_slack %}  - Slack (webhook URL in secret {{ notification.slack_webhook_secret }})
{% endif %}
Usage:
  python scripts/drift_notify.py \\
    --plan-output /tmp/tf_plan_output.txt \\
    --product {{ product_name }} \\
    --env {{ env }} \\
    --status drift \\
    --output /tmp/drift_report.json
"""

from __future__ import annotations

import argparse
import json
import os
import re
import sys
import urllib.request
from datetime import datetime, timezone
from pathlib import Path


_ADD_RE    = re.compile(r"^\s*#.*will be created",    re.MULTILINE)
_CHANGE_RE = re.compile(r"^\s*#.*will be updated",    re.MULTILINE)
_DESTROY_RE= re.compile(r"^\s*#.*will be destroyed",  re.MULTILINE)
_REPLACE_RE= re.compile(r"^\s*#.*must be replaced",   re.MULTILINE)
_SUMMARY_RE= re.compile(
    r"Plan: (\d+) to add, (\d+) to change, (\d+) to destroy", re.MULTILINE
)


def _parse_plan(text: str) -> dict:
    adds     = len(_ADD_RE.findall(text))
    changes  = len(_CHANGE_RE.findall(text))
    destroys = len(_DESTROY_RE.findall(text))
    replaces = len(_REPLACE_RE.findall(text))

    summary_match = _SUMMARY_RE.search(text)
    if summary_match:
        adds     = int(summary_match.group(1))
        changes  = int(summary_match.group(2))
        destroys = int(summary_match.group(3))

    # Extract changed resource names
    changed_resources: list[str] = []
    for line in text.splitlines():
        if "will be" in line or "must be" in line:
            m = re.search(r"#\s+(\S+)\s+(?:will|must) be", line)
            if m:
                changed_resources.append(m.group(1))

    severity = "none"
    if destroys > 0 or replaces > 0:
        severity = "critical"
    elif changes > 0 or adds > 0:
        severity = "warning"

    return {
        "adds": adds,
        "changes": changes,
        "destroys": destroys,
        "replaces": replaces,
        "severity": severity,
        "changed_resources": changed_resources[:20],
    }


def _build_report(args: argparse.Namespace, plan_text: str) -> dict:
    parsed = _parse_plan(plan_text)
    return {
        "product":     args.product,
        "environment": args.env,
        "status":      args.status,
        "detected_at": datetime.now(timezone.utc).isoformat(),
        "summary":     parsed,
        "message":     _build_message(args.product, args.env, args.status, parsed),
    }


def _build_message(product: str, env: str, status: str, parsed: dict) -> str:
    if status == "clean":
        return f"✅ No drift detected in {product} ({env})."
    if status == "error":
        return f"❌ terraform plan failed for {product} ({env}). Check CI logs."

    parts = []
    if parsed["adds"]:
        parts.append(f"{parsed['adds']} to add")
    if parsed["changes"]:
        parts.append(f"{parsed['changes']} to change")
    if parsed["destroys"]:
        parts.append(f"{parsed['destroys']} to destroy")
    if parsed["replaces"]:
        parts.append(f"{parsed['replaces']} to replace")

    summary = ", ".join(parts) or "unknown changes"
    severity_icon = "🔴" if parsed["severity"] == "critical" else "⚠️"
    msg = f"{severity_icon} Drift detected in {product} ({env}): {summary}."

    if parsed["changed_resources"]:
        resources = "\n  - ".join(parsed["changed_resources"][:10])
        msg += f"\n\nAffected resources:\n  - {resources}"

    if parsed["destroys"] > 0 or parsed["replaces"] > 0:
        msg += (
            "\n\n⚠️  DESTRUCTIVE CHANGES detected. "
            "Do NOT run terraform apply without human review."
        )

    return msg

{% if notification.has_teams %}

def notify_teams(report: dict, webhook_url: str) -> None:
    """Post drift report as a Teams Adaptive Card via incoming webhook."""
    severity = report["summary"]["severity"]
    color = "attention" if severity == "critical" else "warning"
    icon  = "🔴" if severity == "critical" else "⚠️"
    s = report["summary"]

    card = {
        "type": "message",
        "attachments": [{
            "contentType": "application/vnd.microsoft.card.adaptive",
            "content": {
                "type": "AdaptiveCard",
                "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
                "version": "1.2",
                "body": [
                    {
                        "type": "TextBlock",
                        "text": f"{icon} Drift Detected — {report['product']} ({report['environment']})",
                        "weight": "Bolder",
                        "size": "Medium",
                        "color": color,
                    },
                    {
                        "type": "FactSet",
                        "facts": [
                            {"title": "Adds",     "value": str(s["adds"])},
                            {"title": "Changes",  "value": str(s["changes"])},
                            {"title": "Destroys", "value": str(s["destroys"])},
                            {"title": "Severity", "value": severity.upper()},
                        ],
                    },
                    {
                        "type": "TextBlock",
                        "text": report["message"][:1000],
                        "wrap": True,
                    },
                ],
            },
        }],
    }

    payload = json.dumps(card).encode()
    req = urllib.request.Request(
        webhook_url, data=payload,
        headers={"Content-Type": "application/json"},
    )
    try:
        with urllib.request.urlopen(req, timeout=15) as resp:
            print(f"Teams notification sent (HTTP {resp.status})")
    except Exception as exc:
        print(f"WARNING: Teams notification failed: {exc}", file=sys.stderr)

{% endif %}
{% if notification.has_slack %}

def notify_slack(report: dict, webhook_url: str) -> None:
    """Post drift report as a Slack Block Kit message via incoming webhook."""
    severity = report["summary"]["severity"]
    color = "#ef4444" if severity == "critical" else "#f59e0b"
    icon  = ":red_circle:" if severity == "critical" else ":warning:"
    s = report["summary"]

    payload = {
        "attachments": [{
            "color": color,
            "blocks": [
                {
                    "type": "header",
                    "text": {
                        "type": "plain_text",
                        "text": f"Drift Detected — {report['product']} ({report['environment']})",
                        "emoji": True,
                    },
                },
                {
                    "type": "section",
                    "fields": [
                        {"type": "mrkdwn", "text": f"*{icon} Severity:* `{severity.upper()}`"},
                        {"type": "mrkdwn", "text": f"*Adds:* {s['adds']}"},
                        {"type": "mrkdwn", "text": f"*Changes:* {s['changes']}"},
                        {"type": "mrkdwn", "text": f"*Destroys:* {s['destroys']}"},
                    ],
                },
                {
                    "type": "section",
                    "text": {
                        "type": "mrkdwn",
                        "text": report["message"][:3000],
                    },
                },
                {"type": "divider"},
            ],
        }],
    }

    data = json.dumps(payload).encode()
    req = urllib.request.Request(
        webhook_url, data=data,
        headers={"Content-Type": "application/json"},
    )
    try:
        with urllib.request.urlopen(req, timeout=15) as resp:
            print(f"Slack notification sent (HTTP {resp.status})")
    except Exception as exc:
        print(f"WARNING: Slack notification failed: {exc}", file=sys.stderr)

{% endif %}

def main() -> None:
    parser = argparse.ArgumentParser(description="Parse terraform plan drift output")
    parser.add_argument("--plan-output", required=True, help="Path to terraform plan stdout")
    parser.add_argument("--product",     required=True, help="Data product name")
    parser.add_argument("--env",         required=True, help="Environment")
    parser.add_argument("--status",      required=True,
                        choices=["clean", "drift", "error"])
    parser.add_argument("--output",      required=True, help="Output JSON report path")
    args = parser.parse_args()

    plan_path = Path(args.plan_output)
    plan_text = plan_path.read_text(encoding="utf-8") if plan_path.exists() else ""

    report = _build_report(args, plan_text)
    Path(args.output).write_text(json.dumps(report, indent=2), encoding="utf-8")
    print(report["message"])

{% if notification.has_teams %}
    teams_url = os.environ.get("DRIFT_TEAMS_WEBHOOK", "")
    if teams_url and report["status"] != "clean":
        notify_teams(report, teams_url)
{% endif %}
{% if notification.has_slack %}
    slack_url = os.environ.get("DRIFT_SLACK_WEBHOOK", "")
    if slack_url and report["status"] != "clean":
        notify_slack(report, slack_url)
{% endif %}

    if args.status in ("drift", "error"):
        sys.exit(1)


if __name__ == "__main__":
    main()
