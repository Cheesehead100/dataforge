#!/usr/bin/env python3
"""
DataForge Drift Notification Parser — {{ product_name }}
Generated by DataForge DriftDetectionGenerator (L8)

Parses `terraform plan -detailed-exitcode` output and produces a structured
drift report. Called by the drift detection CI/CD workflow.

Usage:
  python scripts/drift_notify.py \\
    --plan-output /tmp/tf_plan_output.txt \\
    --product customer360 \\
    --env prod \\
    --status drift \\
    --output /tmp/drift_report.json
"""

from __future__ import annotations

import argparse
import json
import re
import sys
from datetime import datetime, timezone
from pathlib import Path


_ADD_RE    = re.compile(r"^\s*#.*will be created",    re.MULTILINE)
_CHANGE_RE = re.compile(r"^\s*#.*will be updated",    re.MULTILINE)
_DESTROY_RE= re.compile(r"^\s*#.*will be destroyed",  re.MULTILINE)
_REPLACE_RE= re.compile(r"^\s*#.*must be replaced",   re.MULTILINE)
_SUMMARY_RE= re.compile(
    r"Plan: (\d+) to add, (\d+) to change, (\d+) to destroy", re.MULTILINE
)


def _parse_plan(text: str) -> dict:
    adds     = len(_ADD_RE.findall(text))
    changes  = len(_CHANGE_RE.findall(text))
    destroys = len(_DESTROY_RE.findall(text))
    replaces = len(_REPLACE_RE.findall(text))

    summary_match = _SUMMARY_RE.search(text)
    if summary_match:
        adds     = int(summary_match.group(1))
        changes  = int(summary_match.group(2))
        destroys = int(summary_match.group(3))

    # Extract changed resource names
    changed_resources: list[str] = []
    for line in text.splitlines():
        if "will be" in line or "must be" in line:
            # e.g. "  # azurerm_storage_account.main will be updated in-place"
            m = re.search(r"#\s+(\S+)\s+(?:will|must) be", line)
            if m:
                changed_resources.append(m.group(1))

    severity = "none"
    if destroys > 0 or replaces > 0:
        severity = "critical"
    elif changes > 0 or adds > 0:
        severity = "warning"

    return {
        "adds": adds,
        "changes": changes,
        "destroys": destroys,
        "replaces": replaces,
        "severity": severity,
        "changed_resources": changed_resources[:20],  # cap for readability
    }


def _build_report(args: argparse.Namespace, plan_text: str) -> dict:
    parsed = _parse_plan(plan_text)
    return {
        "product":    args.product,
        "environment": args.env,
        "status":     args.status,
        "detected_at": datetime.now(timezone.utc).isoformat(),
        "summary": parsed,
        "message": _build_message(args.product, args.env, args.status, parsed),
    }


def _build_message(product: str, env: str, status: str, parsed: dict) -> str:
    if status == "clean":
        return f"✅ No drift detected in {product} ({env})."
    if status == "error":
        return f"❌ terraform plan failed for {product} ({env}). Check CI logs."

    parts = []
    if parsed["adds"]:
        parts.append(f"{parsed['adds']} to add")
    if parsed["changes"]:
        parts.append(f"{parsed['changes']} to change")
    if parsed["destroys"]:
        parts.append(f"{parsed['destroys']} to destroy")
    if parsed["replaces"]:
        parts.append(f"{parsed['replaces']} to replace")

    summary = ", ".join(parts) or "unknown changes"
    severity_icon = "🔴" if parsed["severity"] == "critical" else "⚠️"
    msg = f"{severity_icon} Drift detected in {product} ({env}): {summary}."

    if parsed["changed_resources"]:
        resources = "\n  - ".join(parsed["changed_resources"][:10])
        msg += f"\n\nAffected resources:\n  - {resources}"

    if parsed["destroys"] > 0 or parsed["replaces"] > 0:
        msg += (
            "\n\n⚠️  DESTRUCTIVE CHANGES detected. "
            "Do NOT run terraform apply without human review."
        )

    return msg


def main() -> None:
    parser = argparse.ArgumentParser(description="Parse terraform plan drift output")
    parser.add_argument("--plan-output", required=True, help="Path to terraform plan stdout")
    parser.add_argument("--product",     required=True, help="Data product name")
    parser.add_argument("--env",         required=True, help="Environment")
    parser.add_argument("--status",      required=True,
                        choices=["clean", "drift", "error"])
    parser.add_argument("--output",      required=True, help="Output JSON report path")
    args = parser.parse_args()

    plan_path = Path(args.plan_output)
    plan_text = plan_path.read_text(encoding="utf-8") if plan_path.exists() else ""

    report = _build_report(args, plan_text)

    Path(args.output).write_text(json.dumps(report, indent=2), encoding="utf-8")
    print(report["message"])

    if args.status in ("drift", "error"):
        sys.exit(1)


if __name__ == "__main__":
    main()
