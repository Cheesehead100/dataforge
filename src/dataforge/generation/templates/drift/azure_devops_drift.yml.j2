# DataForge Drift Detection — {{ product_name }}
# Generated by DataForge DriftDetectionGenerator (L8)
# Pipeline: nightly terraform plan against last applied state
# Exit 0 = drift-free. Exit 2 = drift detected (pipeline fails + alerts).
#
# Variable group "dataforge-{{ env }}-secrets" must contain:
#   ARM_CLIENT_ID, ARM_CLIENT_SECRET, ARM_TENANT_ID, ARM_SUBSCRIPTION_ID
{% if notification.has_teams %}#   {{ notification.teams_webhook_secret }} — Microsoft Teams incoming webhook URL
{% endif %}{% if notification.has_slack %}#   {{ notification.slack_webhook_secret }} — Slack incoming webhook URL
{% endif %}

trigger: none   # manual only; schedule below runs it nightly

schedules:
  - cron: "{{ schedule_cron }}"
    displayName: "Nightly drift check ({{ env }})"
    branches:
      include: [main]
    always: true

variables:
  - name: TF_DIR
    value: $(Build.SourcesDirectory)/{{ tf_dir }}
  - name: PRODUCT
    value: "{{ product_name }}"
  - name: ENV
    value: "{{ env }}"
  - group: "dataforge-{{ env }}-secrets"   # var group with ARM_* and webhook credentials

stages:
  - stage: DriftDetection
    displayName: "Drift Detection — {{ product_name }} ({{ env }})"
    jobs:
      - job: TerraformPlan
        displayName: "terraform plan (drift check)"
        pool:
          vmImage: ubuntu-latest
        steps:
          - checkout: self

          - task: TerraformInstaller@1
            displayName: "Install Terraform"
            inputs:
              terraformVersion: "~1.7"

          - task: TerraformTaskV4@4
            displayName: "terraform init"
            inputs:
              provider: azurerm
              command: init
              workingDirectory: $(TF_DIR)
              backendServiceArm: "dataforge-{{ env }}-service-connection"
              backendAzureRmResourceGroupName: "{{ metadata.resource_group }}"
              backendAzureRmStorageAccountName: "stdfstate{{ env }}"
              backendAzureRmContainerName: tfstate
              backendAzureRmKey: "{{ product_name }}.terraform.tfstate"

          - bash: |
              set +e
              terraform plan \
                -detailed-exitcode \
                -input=false \
                -var="environment=$(ENV)" \
                2>&1 | tee $(Agent.TempDirectory)/tf_plan_output.txt
              EXIT_CODE=${PIPESTATUS[0]}
              echo "##vso[task.setvariable variable=DRIFT_EXIT_CODE]${EXIT_CODE}"

              if [ "${EXIT_CODE}" = "0" ]; then
                echo "##vso[task.setvariable variable=DRIFT_STATUS]clean"
                echo "##vso[task.complete result=Succeeded;]No drift detected for $(PRODUCT) ($(ENV))"
              elif [ "${EXIT_CODE}" = "2" ]; then
                echo "##vso[task.setvariable variable=DRIFT_STATUS]drift"
                echo "##vso[task.logissue type=warning]DRIFT DETECTED in $(PRODUCT) ($(ENV)). Review plan output."
              else
                echo "##vso[task.setvariable variable=DRIFT_STATUS]error"
                echo "##vso[task.logissue type=error]terraform plan failed with exit code ${EXIT_CODE}"
              fi
            displayName: "terraform plan (drift detection)"
            workingDirectory: $(TF_DIR)
            env:
              ARM_CLIENT_ID: $(ARM_CLIENT_ID)
              ARM_CLIENT_SECRET: $(ARM_CLIENT_SECRET)
              ARM_TENANT_ID: $(ARM_TENANT_ID)
              ARM_SUBSCRIPTION_ID: $(ARM_SUBSCRIPTION_ID)

          - bash: |
              pip install -q rich
              python $(Build.SourcesDirectory)/scripts/drift_notify.py \
                --plan-output $(Agent.TempDirectory)/tf_plan_output.txt \
                --product "$(PRODUCT)" \
                --env "$(ENV)" \
                --status "$(DRIFT_STATUS)" \
                --output $(Agent.TempDirectory)/drift_report.json
            displayName: "Parse drift report and send notifications"
            condition: ne(variables['DRIFT_STATUS'], 'clean')
{% if notification.has_teams or notification.has_slack %}
            env:
{% if notification.has_teams %}
              DRIFT_TEAMS_WEBHOOK: $({{ notification.teams_webhook_secret }})
{% endif %}
{% if notification.has_slack %}
              DRIFT_SLACK_WEBHOOK: $({{ notification.slack_webhook_secret }})
{% endif %}
{% endif %}

{% if notification.has_email %}
          - task: SendEmail@0
            displayName: "Alert: drift email notification"
            condition: ne(variables['DRIFT_STATUS'], 'clean')
            inputs:
              To: "{{ notification.email }}"
              From: "DataForge Drift Monitor <noreply@dataforge>"
              Subject: "⚠️ Drift detected: $(PRODUCT) ($(ENV))"
              Body: |
                Terraform drift detected in $(PRODUCT) ($(ENV)).
                Build: $(Build.BuildWebUrl)
              SmtpServer: smtp.gmail.com
              SmtpPort: 587
{% endif %}

          - bash: |
              if [ "$(DRIFT_STATUS)" != "clean" ]; then
                echo "Drift detected or plan error — failing pipeline."
                exit 1
              fi
            displayName: "Fail if drift detected"
