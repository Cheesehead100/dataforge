# DataForge Drift Detection — {{ product_name }}
# Generated by DataForge DriftDetectionGenerator (L8)
#
# Runs nightly terraform plan against the last applied state.
# Exit code 0 = drift-free (no changes).
# Exit code 2 = drift detected — alerts fire and the job fails.
#
# Secrets required (repo Settings → Secrets → Actions):
#   ARM_CLIENT_ID, ARM_CLIENT_SECRET, ARM_TENANT_ID, ARM_SUBSCRIPTION_ID
{% if notification.has_email %}#   DRIFT_SMTP_USER, DRIFT_SMTP_PASSWORD — SMTP credentials for email alerts
{% endif %}{% if notification.has_teams %}#   {{ notification.teams_webhook_secret }} — Microsoft Teams incoming webhook URL
{% endif %}{% if notification.has_slack %}#   {{ notification.slack_webhook_secret }} — Slack incoming webhook URL
{% endif %}
name: "Drift Detection — {{ product_name }}"

on:
  schedule:
    - cron: "{{ schedule_cron }}"   # nightly 02:00 UTC
  workflow_dispatch:                 # allow manual trigger

permissions:
  contents: read
  id-token: write   # required for OIDC auth

jobs:
  detect-drift:
    name: "terraform plan (drift check)"
    runs-on: ubuntu-latest
    environment: {{ env }}

    env:
      ARM_CLIENT_ID: {% raw %}${{ secrets.ARM_CLIENT_ID }}{% endraw %}

      ARM_CLIENT_SECRET: {% raw %}${{ secrets.ARM_CLIENT_SECRET }}{% endraw %}

      ARM_TENANT_ID: {% raw %}${{ secrets.ARM_TENANT_ID }}{% endraw %}

      ARM_SUBSCRIPTION_ID: {% raw %}${{ secrets.ARM_SUBSCRIPTION_ID }}{% endraw %}


    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Setup Terraform
        uses: hashicorp/setup-terraform@v3
        with:
          terraform_version: "~1.7"

      - name: Terraform Init
        id: init
        working-directory: ./{{ tf_dir }}
        run: terraform init -input=false -backend=true

      - name: Terraform Plan (drift detection)
        id: plan
        working-directory: ./{{ tf_dir }}
        run: |
          set +e
          terraform plan \
            -detailed-exitcode \
            -input=false \
            -out=drift.tfplan \
            -var="environment={{ env }}" \
            2>&1 | tee /tmp/tf_plan_output.txt
          EXIT_CODE=${PIPESTATUS[0]}
          echo "exitcode=${EXIT_CODE}" >> $GITHUB_OUTPUT
          echo "## Terraform Plan Output" >> $GITHUB_STEP_SUMMARY
          echo '```' >> $GITHUB_STEP_SUMMARY
          tail -50 /tmp/tf_plan_output.txt >> $GITHUB_STEP_SUMMARY
          echo '```' >> $GITHUB_STEP_SUMMARY
          exit ${EXIT_CODE}
        continue-on-error: true

      - name: Evaluate drift
        id: drift
        run: |
          EXIT_CODE="${{ '{{ steps.plan.outputs.exitcode }}' }}"
          if [ "${EXIT_CODE}" = "0" ]; then
            echo "status=clean"  >> $GITHUB_OUTPUT
            echo "### Drift Status: CLEAN ✅" >> $GITHUB_STEP_SUMMARY
            echo "No infrastructure changes detected for **{{ product_name }}** ({{ env }})." >> $GITHUB_STEP_SUMMARY
          elif [ "${EXIT_CODE}" = "2" ]; then
            echo "status=drift"  >> $GITHUB_OUTPUT
            echo "### Drift Status: DRIFT DETECTED ⚠️" >> $GITHUB_STEP_SUMMARY
            echo "**{{ product_name }}** ({{ env }}) has infrastructure changes not reflected in git." >> $GITHUB_STEP_SUMMARY
            echo "Review the plan above and run \`terraform apply\` or revert manual changes." >> $GITHUB_STEP_SUMMARY
          else
            echo "status=error"  >> $GITHUB_OUTPUT
            echo "### Drift Status: PLAN ERROR ❌" >> $GITHUB_STEP_SUMMARY
            echo "Terraform plan failed with exit code ${EXIT_CODE}." >> $GITHUB_STEP_SUMMARY
          fi

      - name: Parse drift report and send notifications
        if: {% raw %}${{ steps.drift.outputs.status != 'clean' }}{% endraw %}

        env:
{% if notification.has_teams %}
          DRIFT_TEAMS_WEBHOOK: {% raw %}${{ secrets.DRIFT_TEAMS_WEBHOOK }}{% endraw %}

{% endif %}
{% if notification.has_slack %}
          DRIFT_SLACK_WEBHOOK: {% raw %}${{ secrets.DRIFT_SLACK_WEBHOOK }}{% endraw %}

{% endif %}
        run: |
          pip install -q rich
          python scripts/drift_notify.py \
            --plan-output /tmp/tf_plan_output.txt \
            --product "{{ product_name }}" \
            --env "{{ env }}" \
            --status "{{ '{{ steps.drift.outputs.status }}' }}" \
            --output /tmp/drift_report.json

{% if notification.has_email %}
      - name: Send email notification
        if: {% raw %}${{ steps.drift.outputs.status != 'clean' }}{% endraw %}

        uses: dawidd6/action-send-mail@v3
        with:
          server_address: smtp.gmail.com
          server_port: 587
          username: {% raw %}${{ secrets.DRIFT_SMTP_USER }}{% endraw %}

          password: {% raw %}${{ secrets.DRIFT_SMTP_PASSWORD }}{% endraw %}

          to: "{{ notification.email }}"
          from: "DataForge Drift Monitor <noreply@dataforge>"
          subject: "⚠️ Drift detected: {{ product_name }} ({{ env }})"
          body: |
            Terraform drift detected in {{ product_name }} ({{ env }}).
            Review the workflow run for details and remediation steps.
            Run URL: {% raw %}${{ github.server_url }}/${{ github.repository }}/actions/runs/${{ github.run_id }}{% endraw %}

{% endif %}

      - name: Fail if drift detected
        if: {% raw %}${{ steps.drift.outputs.status == 'drift' || steps.drift.outputs.status == 'error' }}{% endraw %}

        run: |
          echo "Drift detected or plan error. See job summary for details."
          exit 1
