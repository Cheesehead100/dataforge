{#
  variables.tf.j2 — Terraform input variable declarations for the generated stack.
  Provisions: common vars (env, location, resource_group, app_name, tags);
  conditional networking vars for Databricks VNet injection; per-node SP object ID
  vars for Databricks and Fabric; SQL MI subnet var; AKS workload-identity vars.
  Context vars: env, location, resource_group, app_name, tags,
  databricks_nodes, fabric_nodes, sql_mi_nodes, aks_nodes.
  Env logic: none — defaults are baked in, overridden per environment via tfvars.
  Constraint: azurerm_client_config + azurerm_resource_group data sources are
  appended here (not in a separate file) to avoid splitting required data lookups.
#}
variable "environment" {
  description = "Deployment environment (dev, test, prod)"
  type        = string
  default     = "{{ env }}"
}

variable "location" {
  description = "Azure region"
  type        = string
  default     = "{{ location }}"
}

variable "resource_group_name" {
  description = "Target Azure resource group name"
  type        = string
  default     = "{{ resource_group }}"
}

variable "application_name" {
  description = "Short application name used in resource naming"
  type        = string
  default     = "{{ app_name }}"
}

variable "tags" {
  description = "Azure tags applied to all resources"
  type        = map(string)
  default = {
{% for key, value in tags.items() %}
    {{ key }} = "{{ value }}"
{% endfor %}
  }
}

{% if databricks_nodes %}
# ── Networking (Databricks VNet injection) ────────────────────────────────────
variable "vnet_address_space" {
  description = "CIDR block for the VNet used by Databricks VNet injection"
  type        = string
  default     = "10.0.0.0/16"
}

variable "dbw_private_subnet_cidr" {
  description = "CIDR for the Databricks private subnet"
  type        = string
  default     = "10.0.1.0/24"
}

variable "dbw_public_subnet_cidr" {
  description = "CIDR for the Databricks public subnet"
  type        = string
  default     = "10.0.2.0/24"
}

variable "pe_subnet_cidr" {
  description = "CIDR for the private-endpoint subnet"
  type        = string
  default     = "10.0.3.0/24"
}

{% endif %}
{% for node in databricks_nodes %}
variable "{{ node.id }}_sp_object_id" {
  description = "Object ID of the service principal used by Databricks workspace '{{ node.name }}' for storage and Key Vault RBAC. Create a service principal in your Databricks account or Unity Catalog and supply its Azure object ID."
  type        = string
  default     = ""
}

{% endfor %}
{% for node in fabric_nodes %}
variable "{{ node.id }}_sp_object_id" {
  description = "Object ID of the service principal for Fabric Lakehouse '{{ node.name }}' to access Azure resources."
  type        = string
  default     = ""
}

variable "{{ node.id }}_workspace_id" {
  description = "Azure resource ID of the Microsoft Fabric workspace for '{{ node.name }}'."
  type        = string
  default     = ""
}

{% endfor %}
{% for node in sql_mi_nodes %}
# ── SQL MI networking ─────────────────────────────────────────────────────────
# SQL Managed Instance requires a dedicated /29 or larger subnet with no other resources.
# Create it in your VNet and provide the resource ID here.
variable "sql_mi_subnet_id" {
  description = "Resource ID of the dedicated subnet for SQL Managed Instance '{{ node.name }}'. The subnet must be delegated to Microsoft.Sql/managedInstances and have no other resources."
  type        = string
}

{% endfor %}
{% for node in aks_nodes %}
# ── AKS Workload Identity: {{ node.name }} ────────────────────────────────────
variable "{{ node.id }}_workload_namespace" {
  description = "Kubernetes namespace of the ServiceAccount used by Spark pods in '{{ node.name }}'"
  type        = string
  default     = "spark"
}

variable "{{ node.id }}_workload_service_account" {
  description = "Kubernetes ServiceAccount name for Spark pods in '{{ node.name }}'"
  type        = string
  default     = "spark-sa"
}

{% endfor %}

data "azurerm_client_config" "current" {}

data "azurerm_resource_group" "rg" {
  name = var.resource_group_name
}
