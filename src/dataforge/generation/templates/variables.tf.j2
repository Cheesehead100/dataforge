variable "environment" {
  description = "Deployment environment (dev, test, prod)"
  type        = string
  default     = "{{ env }}"
}

variable "location" {
  description = "Azure region"
  type        = string
  default     = "{{ location }}"
}

variable "resource_group_name" {
  description = "Target Azure resource group name"
  type        = string
  default     = "{{ resource_group }}"
}

variable "application_name" {
  description = "Short application name used in resource naming"
  type        = string
  default     = "{{ app_name }}"
}

variable "tags" {
  description = "Azure tags applied to all resources"
  type        = map(string)
  default = {
{% for key, value in tags.items() %}
    {{ key }} = "{{ value }}"
{% endfor %}
  }
}

{% for node in databricks_nodes %}
variable "{{ node.id }}_sp_object_id" {
  description = "Object ID of the service principal used by Databricks workspace '{{ node.name }}' for storage and Key Vault RBAC. Create a service principal in your Databricks account or Unity Catalog and supply its Azure object ID."
  type        = string
  default     = ""
}

{% endfor %}
{% for node in fabric_nodes %}
variable "{{ node.id }}_sp_object_id" {
  description = "Object ID of the service principal for Fabric Lakehouse '{{ node.name }}' to access Azure resources."
  type        = string
  default     = ""
}

variable "{{ node.id }}_workspace_id" {
  description = "Azure resource ID of the Microsoft Fabric workspace for '{{ node.name }}'."
  type        = string
  default     = ""
}

{% endfor %}

data "azurerm_client_config" "current" {}

data "azurerm_resource_group" "rg" {
  name = var.resource_group_name
}
