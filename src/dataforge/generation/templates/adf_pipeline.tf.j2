# ── ADF Pipeline Resources: {{ product_name }} ───────────────────────────────
# Generated by DataForge AdfPipelineGenerator
# These resources create the ADF pipeline INSIDE the factory provisioned by data_factory.tf.
# Depends on: azurerm_data_factory.*, azurerm_key_vault.*, azurerm_storage_account.*

data "azurerm_data_factory" "main" {
  name                = "adf-${var.application_name}-${var.environment}"
  resource_group_name = var.resource_group_name
}

data "azurerm_key_vault" "main" {
  name                = "kv-${var.application_name}-${var.environment}"
  resource_group_name = var.resource_group_name
}

# ── Linked Service: Azure Key Vault ──────────────────────────────────────────
# ADF reads all secrets (connection strings, tokens) from Key Vault.
resource "azurerm_data_factory_linked_service_key_vault" "main" {
  name            = "ls-keyvault-${var.application_name}-${var.environment}"
  data_factory_id = data.azurerm_data_factory.main.id
  key_vault_id    = data.azurerm_key_vault.main.id
}

{% if has_sql_source %}
# ── Linked Service: SQL Server / SQL MI ──────────────────────────────────────
resource "azurerm_data_factory_linked_service_sql_server" "source_sql" {
  name            = "ls-sqlserver-${var.application_name}-${var.environment}"
  data_factory_id = data.azurerm_data_factory.main.id

  # Connection string stored in Key Vault as secret "sql-connection-string"
  key_vault_connection_string {
    linked_service_name = azurerm_data_factory_linked_service_key_vault.main.name
    secret_name         = "sql-connection-string"
  }
}
{% endif %}

{% if has_eventhub_source %}
# ── Linked Service: Azure Event Hub ──────────────────────────────────────────
resource "azurerm_data_factory_linked_service_azure_blob_storage" "eventhub_capture" {
  name              = "ls-eventhub-capture-${var.application_name}-${var.environment}"
  data_factory_id   = data.azurerm_data_factory.main.id
  sas_uri           = "@Microsoft.KeyVault(SecretUri=https://kv-${var.application_name}-${var.environment}.vault.azure.net/secrets/eventhub-capture-sas/)"
}
{% endif %}

# ── Linked Service: ADLS Gen2 (sink) ─────────────────────────────────────────
resource "azurerm_data_factory_linked_service_data_lake_storage_gen2" "sink_adls" {
  name                 = "ls-adls-${var.application_name}-${var.environment}"
  data_factory_id      = data.azurerm_data_factory.main.id
  use_managed_identity = true
  url                  = "https://st${replace(var.application_name, "-", "")}${var.environment}.dfs.core.windows.net"
}

{% for pipeline in pipelines %}
# ── Pipeline: {{ pipeline.display_name }} ─────────────────────────────────────

{% if pipeline.source_type == "sql_mi" %}
resource "azurerm_data_factory_dataset_sql_server_table" "src_{{ pipeline.safe_name }}" {
  name                = "ds-src-{{ pipeline.safe_name }}-${var.environment}"
  data_factory_id     = data.azurerm_data_factory.main.id
  linked_service_name = azurerm_data_factory_linked_service_sql_server.source_sql.name

  parameters = {
    schema_name = "dbo"
    table_name  = var.{{ pipeline.safe_name }}_source_table
  }
}
{% elif pipeline.source_type == "eventhub" %}
resource "azurerm_data_factory_dataset_azure_blob" "src_{{ pipeline.safe_name }}" {
  name                = "ds-src-{{ pipeline.safe_name }}-${var.environment}"
  data_factory_id     = data.azurerm_data_factory.main.id
  linked_service_name = azurerm_data_factory_linked_service_azure_blob_storage.eventhub_capture.name
  path                = "eventhub-capture"
  filename            = "*.avro"
}
{% endif %}

resource "azurerm_data_factory_dataset_parquet" "sink_{{ pipeline.safe_name }}_bronze" {
  name                = "ds-sink-{{ pipeline.safe_name }}-bronze-${var.environment}"
  data_factory_id     = data.azurerm_data_factory.main.id
  linked_service_name = azurerm_data_factory_linked_service_data_lake_storage_gen2.sink_adls.name

  azure_blob_storage_location {
    container = "bronze"
    path      = "{{ pipeline.source_name | lower | replace(' ', '_') }}"
    filename  = "@concat('{{ pipeline.source_name | lower | replace(' ', '_') }}', '_', formatDateTime(utcnow(), 'yyyyMMddHHmmss'), '.parquet')"
  }

  compression_codec = "snappy"
}

resource "azurerm_data_factory_pipeline" "{{ pipeline.safe_name }}" {
  name            = "pl-{{ pipeline.display_name }}-${var.environment}"
  data_factory_id = data.azurerm_data_factory.main.id

  description = "{{ product_name }}: ingest {{ pipeline.source_name }} → bronze ADLS"

  variables = {
    batch_size  = "{{ pipeline.batch_size }}"
    watermark   = ""
  }

  activities_json = jsonencode([
    {
      name = "CopyToBronze"
      type = "Copy"
      inputs = [{ referenceName = azurerm_data_factory_dataset_{% if pipeline.source_type == "sql_mi" %}sql_server_table{% else %}azure_blob{% endif %}.src_{{ pipeline.safe_name }}.name, type = "DatasetReference" }]
      outputs = [{ referenceName = azurerm_data_factory_dataset_parquet.sink_{{ pipeline.safe_name }}_bronze.name, type = "DatasetReference" }]
      typeProperties = {
        source = {
          type = {% if pipeline.source_type == "sql_mi" %}"SqlServerSource"{% else %}"BlobSource"{% endif %}
          queryTimeout        = "02:00:00"
          partitionOption     = "None"
        }
        sink = {
          type               = "ParquetSink"
          storeSettings      = { type = "AzureBlobFSWriteSettings" }
          formatSettings     = { type = "ParquetWriteSettings" }
        }
        enableStaging             = false
        parallelCopies            = {{ pipeline.parallelism }}
        enableSkipIncompatibleRow = true
        redirectIncompatibleRowSettings = {
          linkedServiceName = { referenceName = azurerm_data_factory_linked_service_data_lake_storage_gen2.sink_adls.name, type = "LinkedServiceReference" }
          path = "bronze/_rejected"
        }
      }
      policy = {
        timeout             = "0.12:00:00"
        retry               = 3
        retryIntervalInSeconds = 30
        secureOutput        = false
        secureInput         = false
      }
    },
    {
      name = "SetWatermark"
      type = "SetVariable"
      dependsOn = [{ activity = "CopyToBronze", dependencyConditions = ["Succeeded"] }]
      typeProperties = {
        variableName = "watermark"
        value        = { value = "@utcnow()", type = "Expression" }
      }
    }
  ])

  parameters = {
    {% if pipeline.source_type == "sql_mi" %}
    schema_name = { type = "String", defaultValue = "dbo" }
    table_name  = { type = "String" }
    {% endif %}
    watermark_column = { type = "String", defaultValue = "updated_at" }
  }
}

# Trigger: daily schedule (override in prod with event-based trigger)
resource "azurerm_data_factory_trigger_schedule" "{{ pipeline.safe_name }}" {
  name            = "trg-{{ pipeline.display_name }}-daily-${var.environment}"
  data_factory_id = data.azurerm_data_factory.main.id
  pipeline_name   = azurerm_data_factory_pipeline.{{ pipeline.safe_name }}.name

  interval  = 1
  frequency = "Day"
  start_time = "2024-01-01T06:00:00Z"

  activated = var.environment == "prod"
}

{% endfor %}

{% for pipeline in pipelines %}
variable "{{ pipeline.safe_name }}_source_table" {
  type        = string
  description = "Source table name for pipeline {{ pipeline.display_name }}"
  default     = ""
}
{% endfor %}
