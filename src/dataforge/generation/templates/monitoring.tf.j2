{#
  monitoring.tf.j2 — Azure Monitor action group, metric alerts, and cost budget.
  Provisions: azurerm_monitor_action_group (when email_channels is set),
  azurerm_monitor_metric_alert per alert in the alerts list, and
  azurerm_consumption_budget_resource_group (when cost_budget is configured).
  Context vars: app, env, product_name, email_channels, alerts, cost_budget,
  budget_start_date, tags.
  Env logic: none — all alerts and budgets are emitted unconditionally; alert
  severity and threshold values come from the alerts list in the FlowGraph config.
  Constraint: Alert scopes target the resource group, not individual resources;
  namespace/metric names must match Azure Monitor schema exactly.
#}
# ── Monitoring: {{ product_name }} ───────────────────────────────────────────
# Generated by DataForge MonitoringGenerator (L6)

data "azurerm_resource_group" "monitored" {
  name = var.resource_group_name
}

{% if email_channels %}
resource "azurerm_monitor_action_group" "{{ app }}" {
  name                = "ag-{{ app }}-{{ env }}"
  resource_group_name = var.resource_group_name
  short_name          = "{{ (app ~ env)[:12] }}"
  tags                = var.tags

{% for channel in email_channels %}
  email_receiver {
    name          = "{{ channel.name }}"
    email_address = "{{ channel.address }}"
  }
{% endfor %}
}

{% endif %}
{% for alert in alerts %}
resource "azurerm_monitor_metric_alert" "{{ app }}_{{ alert.id }}" {
  name                = "alert-{{ app }}-{{ alert.name }}-{{ env }}"
  resource_group_name = var.resource_group_name
  scopes              = [data.azurerm_resource_group.monitored.id]
  description         = "{{ alert.name }} — {{ product_name }}"
  severity            = {{ alert.severity_code }}
  window_size         = "PT{{ alert.window_minutes }}M"
  frequency           = "PT1M"
  tags                = var.tags

  criteria {
    metric_namespace = "{{ alert.namespace }}"
    metric_name      = "{{ alert.metric }}"
    aggregation      = "Total"
    operator         = "GreaterThan"
    threshold        = {{ alert.threshold }}
  }

{% if email_channels %}
  action {
    action_group_id = azurerm_monitor_action_group.{{ app }}.id
  }
{% endif %}
}

{% endfor %}
{% if cost_budget %}
resource "azurerm_consumption_budget_resource_group" "{{ app }}" {
  name              = "budget-{{ app }}-{{ env }}"
  resource_group_id = data.azurerm_resource_group.monitored.id

  amount     = {{ cost_budget.amount }}
  time_grain = "Monthly"

  time_period {
    start_date = "{{ budget_start_date }}"
  }

{% for threshold in cost_budget.thresholds %}
  notification {
    enabled        = true
    threshold      = {{ threshold }}
    operator       = "GreaterThan"
    threshold_type = "Actual"
{% if email_channels %}
    contact_groups = [azurerm_monitor_action_group.{{ app }}.id]
{% endif %}
  }

{% endfor %}
}
{% endif %}
