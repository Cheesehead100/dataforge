#!/usr/bin/env bash
# DataForge Platform Readiness Gate — {{ product_name }} ({{ env }})
# Generated by DataForge ReadinessGenerator (L8)
#
# Usage (called by CI/CD after Ansible completes):
#   bash tests/readiness/run_readiness.sh
#
# Required environment variables (from terraform output):
#   DATABRICKS_HOST          — e.g. https://adb-xxx.azuredatabricks.net
#   DATABRICKS_TOKEN         — PAT or AAD token
#   STORAGE_ACCOUNT_NAME     — e.g. stcustomer360dev
#   KEY_VAULT_URI            — e.g. https://kv-customer360-dev.vault.azure.net
#   KEY_VAULT_RESOURCE_ID    — ARM resource ID of the Key Vault
#   UNITY_METASTORE_ID       — Unity Catalog metastore ID
#   DATABRICKS_WORKSPACE_ID  — numeric workspace ID
#
# Exit codes:
#   0 = all checks passed (platform is ready, promote to next environment)
#   1 = one or more checks failed (block promotion, alert on-call)

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/../.." && pwd)"

echo "==================================================================="
echo "  DataForge Readiness Gate"
echo "  Product : {{ product_name }}"
echo "  Env     : {{ env }}"
echo "  Date    : $(date -u +%Y-%m-%dT%H:%M:%SZ)"
echo "==================================================================="

# ── Install dependencies ──────────────────────────────────────────────────────
echo ""
echo ">> Installing readiness test dependencies..."
pip install -q -r "${SCRIPT_DIR}/requirements.txt"

# ── Source terraform outputs ──────────────────────────────────────────────────
TF_OUTPUT_FILE="${REPO_ROOT}/tf_outputs.json"
if [[ -f "${TF_OUTPUT_FILE}" ]]; then
  echo ">> Loading terraform outputs from ${TF_OUTPUT_FILE}..."
  export STORAGE_ACCOUNT_NAME=$(jq -r '.storage_account_name.value // empty' "${TF_OUTPUT_FILE}")
  export DATABRICKS_HOST=$(jq -r '.databricks_workspace_url.value // empty' "${TF_OUTPUT_FILE}")
  export KEY_VAULT_URI=$(jq -r '.key_vault_uri.value // empty' "${TF_OUTPUT_FILE}")
  export KEY_VAULT_RESOURCE_ID=$(jq -r '.key_vault_id.value // empty' "${TF_OUTPUT_FILE}")
  export UNITY_METASTORE_ID=$(jq -r '.unity_metastore_id.value // empty' "${TF_OUTPUT_FILE}")
  export DATABRICKS_WORKSPACE_ID=$(jq -r '.databricks_workspace_id.value // empty' "${TF_OUTPUT_FILE}")
fi

# ── Run readiness tests ───────────────────────────────────────────────────────
echo ""
echo ">> Running platform readiness checks..."
REPORT_FILE="${SCRIPT_DIR}/readiness-report-{{ env }}-$(date +%Y%m%d-%H%M%S).xml"

pytest "${SCRIPT_DIR}/test_storage.py" \
       "${SCRIPT_DIR}/test_platform.py" \
       -v \
       --tb=short \
       --timeout=300 \
       --junit-xml="${REPORT_FILE}" \
       -m "readiness" \
       2>&1

EXIT_CODE=$?

echo ""
if [[ ${EXIT_CODE} -eq 0 ]]; then
  echo "==================================================================="
  echo "  READINESS GATE: PASSED"
  echo "  Platform '{{ product_name }}' ({{ env }}) is ready."
  echo "  Safe to promote to next environment."
  echo "==================================================================="
else
  echo "==================================================================="
  echo "  READINESS GATE: FAILED"
  echo "  Platform '{{ product_name }}' ({{ env }}) is NOT ready."
  echo "  Review failures above. DO NOT promote to next environment."
  echo "  Report: ${REPORT_FILE}"
  echo "==================================================================="
fi

exit ${EXIT_CODE}
