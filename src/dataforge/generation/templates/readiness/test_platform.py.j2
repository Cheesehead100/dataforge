@pytest.mark.readiness
class TestDatabricksReadiness:
    """Assert Databricks workspace is configured and reachable."""

    def test_workspace_reachable(self, dbx):
        me = dbx.current_user.me()
        assert me.user_name, "Cannot retrieve current user — workspace unreachable or token invalid"

    def test_cluster_policy_exists(self, dbx, product_name, environment):
        policies = list(dbx.cluster_policies.list())
        expected = f"{product_name}-{environment}-policy"
        names = [p.name for p in policies]
        assert expected in names, (
            f"Cluster policy '{expected}' not found. "
            f"Found: {names}. Run Ansible playbook to create it."
        )

