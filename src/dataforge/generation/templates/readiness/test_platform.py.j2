# ── End-to-End Smoke ──────────────────────────────────────────────────────────

{% if has_databricks and has_adls %}
@pytest.mark.readiness
@pytest.mark.smoke
class TestEndToEndSmoke:
    """Write a synthetic row to Delta bronze, read it back, verify round-trip."""

    SMOKE_TABLE = "dataforge_readiness_check"

    def test_delta_write_read_roundtrip(self, dbx, product_name, environment):
        """
        Submits a single-task ephemeral Databricks job that:
          1. Writes one row to Delta bronze
          2. Reads it back
          3. Asserts equality
        Job exit 0 = pass, non-zero = fail (blocks promotion).
        """
        import time

        script = (
{% raw %}
            "import uuid\n"
            "from pyspark.sql import SparkSession\n"
            "spark = SparkSession.builder.getOrCreate()\n"
            "uid = str(uuid.uuid4())\n"
{% endraw %}
            f"df = spark.createDataFrame([(uid, '{{ product_name }}', '{{ env }}')], ['id','product','env'])\n"
            f"df.write.format('delta').mode('overwrite').saveAsTable('{{ catalog }}.bronze.{self.SMOKE_TABLE}')\n"
{% raw %}
            "result = spark.sql(\n"
            f"  \"SELECT * FROM {{ catalog }}.bronze.{self.SMOKE_TABLE} WHERE id='\" + uid + \"'\")\n"
            "assert result.count() == 1, f'Round-trip failed: wrote id={uid}, got {result.count()} rows'\n"
            "print('SMOKE_PASS')\n"
{% endraw %}
        )

        run = dbx.jobs.submit(
            run_name=f"dataforge-readiness-{environment}",
            tasks=[{
                "task_key": "smoke",
                "spark_python_task": {"python_file": "dbfs:/tmp/df_smoke.py"},
                "new_cluster": {
                    "num_workers": 1,
                    "spark_version": "14.3.x-scala2.12",
                    "node_type_id": "Standard_DS3_v2",
                },
            }],
        )

        # Poll until complete (max 10 min)
        deadline = time.time() + 600
        while time.time() < deadline:
            state = dbx.runs.get(run_id=run.run_id).state
            if state.life_cycle_state.value in ("TERMINATED", "SKIPPED", "INTERNAL_ERROR"):
                break
            time.sleep(15)

        final = dbx.runs.get(run_id=run.run_id)
        result_state = final.state.result_state.value if final.state.result_state else "UNKNOWN"
        assert result_state == "SUCCESS", (
            f"Smoke job failed with result_state={result_state}. "
            f"Run URL: {final.run_page_url}"
        )
{% endif %}


# ── SLA Freshness ─────────────────────────────────────────────────────────────

{% if has_adls %}
@pytest.mark.readiness
class TestSlaReadiness:
    """Assert deployment SLA: platform ready within {{ sla_freshness_hours }}h of YAML declaration."""

    def test_all_containers_accessible(self, blob_client):
        containers = {c["name"] for c in blob_client.list_containers()}
        missing = {"bronze", "silver", "gold"} - containers
        assert not missing, f"Containers not yet created: {missing}"

    def test_private_endpoint_dns_resolves(self):
        import socket
        storage_account = os.environ.get("STORAGE_ACCOUNT_NAME", "")
        if not storage_account:
            pytest.skip("STORAGE_ACCOUNT_NAME not set")
        host = f"{storage_account}.blob.core.windows.net"
        try:
            socket.getaddrinfo(host, 443)
        except socket.gaierror as exc:
            pytest.fail(
                f"DNS resolution failed for {host}: {exc}. "
                "Private endpoint may not be provisioned or DNS zone not linked."
            )
{% endif %}
