from __future__ import annotations

import uuid
import pytest

{% if not has_adls %}
pytestmark = pytest.mark.skip(reason="No ADLS node in pipeline graph")
{% endif %}


@pytest.mark.readiness
class TestStorageReadiness:
    """Assert ADLS Gen2 storage is accessible and medallion containers exist."""

    LAYERS = ["bronze", "silver", "gold"]

    def test_bronze_container_exists(self, blob_client):
        containers = {c["name"] for c in blob_client.list_containers()}
        assert "bronze" in containers, (
            "bronze container not found — Terraform may not have created it "
            "or private endpoint DNS is not yet propagated"
        )

    def test_silver_container_exists(self, blob_client):
        containers = {c["name"] for c in blob_client.list_containers()}
        assert "silver" in containers

    def test_gold_container_exists(self, blob_client):
        containers = {c["name"] for c in blob_client.list_containers()}
        assert "gold" in containers

    def test_write_to_bronze(self, blob_client):
        """Verify MSI has write access to bronze layer."""
        container = blob_client.get_container_client("bronze")
        test_key = f"dataforge-readiness/{uuid.uuid4().hex}.txt"
        container.upload_blob(test_key, b"dataforge-readiness-check", overwrite=True)
        # Cleanup
        container.delete_blob(test_key)

    def test_read_from_bronze(self, blob_client):
        """Verify MSI has read access to bronze layer."""
        container = blob_client.get_container_client("bronze")
        test_key = f"dataforge-readiness/read-{uuid.uuid4().hex}.txt"
        payload = b"dataforge-readiness-read-check"
        container.upload_blob(test_key, payload, overwrite=True)
        blob = container.download_blob(test_key)
        assert blob.readall() == payload
        container.delete_blob(test_key)

    def test_no_public_access(self, blob_client):
        """Assert containers are not publicly accessible (security gate)."""
        for layer in self.LAYERS:
            props = blob_client.get_container_client(layer).get_container_properties()
            public_access = props.get("public_access", None)
            assert public_access is None or public_access == "None", (
                f"{layer} container has public access enabled — this is a security violation"
            )
