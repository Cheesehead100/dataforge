{#
  cicd/azure_devops.yml.j2 — Azure DevOps multi-environment Terraform CI/CD pipeline.
  Stages: Validate (PR gate with configurable security/cost gates) → Deploy per
  environment in the environments list, each depending on the prior environment.
  Context vars: product_name, app, gates (set of gate names), environments (list
  with name, approval_required, smoke_test), env.
  Env logic: Validate stage runs on PRs only; Deploy stages run on pushes to main.
  Each environment can optionally run a smoke test after apply.
  Constraint: Per-environment ARM credentials must be stored as ADO variable groups
  named ARM_CLIENT_ID_<ENV>, ARM_CLIENT_SECRET_<ENV>, etc.
#}
# DataForge CI/CD — {{ product_name }}
# Generated by DataForge CiCdGenerator (L5)
name: "dataforge-{{ app }}"

trigger:
  branches:
    include: [main]
  paths:
    include: ["**.tf", "**.tfvars", "data-product.yaml"]

pr:
  branches:
    include: [main]

variables:
  TF_VERSION: "1.9.x"
  PYTHON_VERSION: "3.11"

stages:
  # ── PR Validation ────────────────────────────────────────────────────────────
  - stage: Validate
    displayName: "Validate"
    condition: eq(variables['Build.Reason'], 'PullRequest')
    jobs:
      - job: ValidateJob
        displayName: "Security + Cost + Quality Gates"
        pool:
          vmImage: ubuntu-latest
        steps:
          - task: UsePythonVersion@0
            inputs:
              versionSpec: $(PYTHON_VERSION)

          - script: pip install -e ".[dev]"
            displayName: "Install dependencies"

{% if "terraform_format" in gates %}
          - script: terraform fmt -check -recursive
            displayName: "Terraform Format"
{% endif %}

{% if "terraform_validate" in gates %}
          - script: |
              terraform init -backend=false
              terraform validate
            displayName: "Terraform Validate"
{% endif %}

{% if "checkov_scan" in gates %}
          - script: checkov -d . --framework terraform --output sarif --output-file-path $(Build.ArtifactStagingDirectory)/checkov.sarif
            displayName: "Checkov Security Scan"
{% endif %}

{% if "tfsec_scan" in gates %}
          - script: tfsec . --format sarif --out $(Build.ArtifactStagingDirectory)/tfsec.sarif
            displayName: "tfsec Scan"
{% endif %}

{% if "python_unit_tests" in gates %}
          - script: pytest tests/unit/ -q --junitxml=$(Build.ArtifactStagingDirectory)/test-results.xml
            displayName: "Python Unit Tests"
          - task: PublishTestResults@2
            inputs:
              testResultsFiles: "$(Build.ArtifactStagingDirectory)/test-results.xml"
{% endif %}

{% if "cost_estimate" in gates %}
          - script: infracost breakdown --path . --format json --out-file $(Build.ArtifactStagingDirectory)/infracost.json
            displayName: "Cost Estimate"
            env:
              INFRACOST_API_KEY: $(INFRACOST_API_KEY)
{% endif %}

          - task: PublishBuildArtifacts@1
            inputs:
              PathtoPublish: $(Build.ArtifactStagingDirectory)
              ArtifactName: security-and-cost-reports

  # ── Deploy stages ────────────────────────────────────────────────────────────
{% for env in environments %}
  - stage: Deploy_{{ env.name | title }}
    displayName: "Deploy → {{ env.name }}"
    dependsOn:
{% if loop.first %}
      - Validate
{% else %}
      - Deploy_{{ environments[loop.index0 - 1].name | title }}
{% endif %}
    condition: and(succeeded(), eq(variables['Build.SourceBranch'], 'refs/heads/main'))
    jobs:
      - deployment: TerraformApply_{{ env.name }}
        displayName: "Terraform Apply ({{ env.name }})"
        environment: "{{ env.name }}"
        pool:
          vmImage: ubuntu-latest
        strategy:
          runOnce:
            deploy:
              steps:
                - checkout: self

                - script: |
                    terraform init
                    terraform plan -var-file=envs/{{ env.name }}.tfvars -out=tfplan
                    terraform apply -auto-approve tfplan
                  displayName: "Terraform Apply"
                  env:
                    ARM_CLIENT_ID: $(ARM_CLIENT_ID_{{ env.name | upper }})
                    ARM_CLIENT_SECRET: $(ARM_CLIENT_SECRET_{{ env.name | upper }})
                    ARM_SUBSCRIPTION_ID: $(ARM_SUBSCRIPTION_ID_{{ env.name | upper }})
                    ARM_TENANT_ID: $(ARM_TENANT_ID)
{% if env.smoke_test %}

                - script: python tests/smoke/smoke_test.py --env {{ env.name }}
                  displayName: "Smoke Test"
{% endif %}

{% endfor %}
