# DataForge CI/CD — {{ product_name }}
# Generated by DataForge CiCdGenerator (L5)
name: "dataforge-{{ app }}"

on:
  pull_request:
    branches: [main]
    paths:
      - "**.tf"
      - "**.tfvars"
      - "data-product.yaml"
  push:
    branches: [main]

env:
  TF_VERSION: "1.9.x"
  PYTHON_VERSION: "3.11"

jobs:
  # ── PR Gate ─────────────────────────────────────────────────────────────────
  validate:
    name: "Validate"
    runs-on: ubuntu-latest
    if: github.event_name == 'pull_request'
    steps:
      - uses: actions/checkout@v4

      - name: Setup Terraform
        uses: hashicorp/setup-terraform@v3
        with:
          terraform_version: ${{ "{{" }} env.TF_VERSION {{ "}}" }}

      - name: Setup Python
        uses: actions/setup-python@v5
        with:
          python-version: ${{ "{{" }} env.PYTHON_VERSION {{ "}}" }}

      - name: Install dependencies
        run: pip install -e ".[dev]"

{% if "terraform_format" in gates %}
      - name: Terraform Format
        run: terraform fmt -check -recursive
{% endif %}

{% if "terraform_validate" in gates %}
      - name: Terraform Validate
        run: |
          terraform init -backend=false
          terraform validate
{% endif %}

{% if "checkov_scan" in gates %}
      - name: Checkov Security Scan
        uses: bridgecrewio/checkov-action@v12
        with:
          directory: .
          framework: terraform
          output_format: sarif
          output_file_path: reports/checkov.sarif
          soft_fail: false
{% endif %}

{% if "tfsec_scan" in gates %}
      - name: tfsec Scan
        uses: aquasecurity/tfsec-action@v1
        with:
          soft_fail: false
{% endif %}

{% if "python_unit_tests" in gates %}
      - name: Python Unit Tests
        run: pytest tests/unit/ -q
{% endif %}

{% if "cost_estimate" in gates %}
      - name: Cost Estimate (infracost)
        uses: infracost/actions/setup@v3
        with:
          api-key: ${{ "{{" }} secrets.INFRACOST_API_KEY {{ "}}" }}
      - name: Generate cost estimate
        run: infracost breakdown --path . --format json --out-file /tmp/infracost.json
      - name: Post cost comment
        uses: infracost/actions/comment@v3
        with:
          path: /tmp/infracost.json
          behavior: update
{% endif %}

{% if "policy_validation" in gates %}
      - name: Policy Validation
        run: python -m dataforge validate .
{% endif %}

      - name: Upload security reports
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: security-reports
          path: reports/

  # ── Deploy stages ────────────────────────────────────────────────────────────
{% for env in environments %}
  deploy-{{ env.name }}:
    name: "Deploy → {{ env.name }}"
    runs-on: ubuntu-latest
    needs: [validate]
    if: github.ref == 'refs/heads/main' && github.event_name == 'push'
{% if env.approval_required %}
    environment:
      name: {{ env.name }}
{% endif %}
{% if not loop.first %}
    needs: [deploy-{{ environments[loop.index0 - 1].name }}]
{% endif %}
    steps:
      - uses: actions/checkout@v4

      - name: Setup Terraform
        uses: hashicorp/setup-terraform@v3
        with:
          terraform_version: ${{ "{{" }} env.TF_VERSION {{ "}}" }}

      - name: Terraform Init
        run: terraform init
        env:
          ARM_CLIENT_ID: ${{ "{{" }} secrets.ARM_CLIENT_ID_{{ env.name | upper }} {{ "}}" }}
          ARM_CLIENT_SECRET: ${{ "{{" }} secrets.ARM_CLIENT_SECRET_{{ env.name | upper }} {{ "}}" }}
          ARM_SUBSCRIPTION_ID: ${{ "{{" }} secrets.ARM_SUBSCRIPTION_ID_{{ env.name | upper }} {{ "}}" }}
          ARM_TENANT_ID: ${{ "{{" }} secrets.ARM_TENANT_ID {{ "}}" }}

      - name: Terraform Plan
        run: terraform plan -var-file=envs/{{ env.name }}.tfvars -out=tfplan
        env:
          ARM_CLIENT_ID: ${{ "{{" }} secrets.ARM_CLIENT_ID_{{ env.name | upper }} {{ "}}" }}
          ARM_CLIENT_SECRET: ${{ "{{" }} secrets.ARM_CLIENT_SECRET_{{ env.name | upper }} {{ "}}" }}
          ARM_SUBSCRIPTION_ID: ${{ "{{" }} secrets.ARM_SUBSCRIPTION_ID_{{ env.name | upper }} {{ "}}" }}
          ARM_TENANT_ID: ${{ "{{" }} secrets.ARM_TENANT_ID {{ "}}" }}

      - name: Terraform Apply
        run: terraform apply -auto-approve tfplan
        env:
          ARM_CLIENT_ID: ${{ "{{" }} secrets.ARM_CLIENT_ID_{{ env.name | upper }} {{ "}}" }}
          ARM_CLIENT_SECRET: ${{ "{{" }} secrets.ARM_CLIENT_SECRET_{{ env.name | upper }} {{ "}}" }}
          ARM_SUBSCRIPTION_ID: ${{ "{{" }} secrets.ARM_SUBSCRIPTION_ID_{{ env.name | upper }} {{ "}}" }}
          ARM_TENANT_ID: ${{ "{{" }} secrets.ARM_TENANT_ID {{ "}}" }}
{% if env.smoke_test %}

      - name: Smoke Test
        run: python tests/smoke/smoke_test.py --env {{ env.name }}
{% endif %}

{% endfor %}
