"""
DataForge Quality Checks — {{ product_name }}
Layer: {{ layer }}  Table: {{ catalog }}.{{ layer }}.{{ table }}

Run this script as a Databricks job after each pipeline execution.
Exit code 0 = all checks passed. Non-zero = at least one check failed.
"""
# Generated by DataForge QualityGenerator (L4)

import sys
from pyspark.sql import SparkSession
from pyspark.sql import functions as F

spark = SparkSession.builder.getOrCreate()

CATALOG = "{{ catalog }}"
LAYER   = "{{ layer }}"
TABLE   = "{{ table }}"
FQN     = f"{CATALOG}.{LAYER}.{TABLE}"

failures: list[str] = []


def fail(msg: str) -> None:
    print(f"[FAIL] {msg}", file=sys.stderr)
    failures.append(msg)


def ok(msg: str) -> None:
    print(f"[PASS] {msg}")


try:
    df = spark.table(FQN)
    row_count = df.count()
    ok(f"Loaded {FQN}: {row_count:,} rows")
except Exception as e:
    fail(f"Cannot load {FQN}: {e}")
    sys.exit(1)

{% for rule in rules %}
{% if rule.type == "not_null" %}
# ── not_null: {{ rule.columns }} ──────────────────────────────
for col in {{ rule.columns | tojson }}:
    nulls = df.filter(F.col(col).isNull()).count()
    if nulls > 0:
        fail(f"not_null: column '{col}' has {nulls:,} null values in {FQN}")
    else:
        ok(f"not_null: '{col}' — no nulls")

{% elif rule.type == "unique" %}
# ── unique: {{ rule.columns }} ────────────────────────────────
for col in {{ rule.columns | tojson }}:
    total = df.count()
    distinct = df.select(col).distinct().count()
    if total != distinct:
        fail(f"unique: column '{col}' has {total - distinct:,} duplicates in {FQN}")
    else:
        ok(f"unique: '{col}' — all values distinct")

{% elif rule.type == "accepted_values" %}
# ── accepted_values: {{ rule.column }} ────────────────────────
_allowed = {{ rule["values"] | tojson }}
_bad = df.filter(~F.col("{{ rule.column }}").isin(_allowed)).count()
if _bad > 0:
    fail(f"accepted_values: '{{ rule.column }}' has {_bad:,} rows with unexpected values in {FQN}")
else:
    ok(f"accepted_values: '{{ rule.column }}' — all values in allowed set")

{% elif rule.type == "row_count_between" %}
# ── row_count_between: {{ rule.min }} – {{ rule.max }} ────────
if not ({{ rule.min }} <= row_count <= {{ rule.max }}):
    fail(f"row_count_between: {FQN} has {row_count:,} rows (expected {{ rule.min }}–{{ rule.max }})")
else:
    ok(f"row_count_between: {row_count:,} rows — within bounds")

{% elif rule.type == "row_count_gt" %}
# ── row_count_gt: {{ rule.value }} ────────────────────────────
if row_count <= {{ rule.value }}:
    fail(f"row_count_gt: {FQN} has {row_count:,} rows (expected > {{ rule.value }})")
else:
    ok(f"row_count_gt: {row_count:,} rows > {{ rule.value }}")

{% elif rule.type == "value_between" %}
# ── value_between: {{ rule.column }} ──────────────────────────
_out_of_range = df.filter(
    (F.col("{{ rule.column }}") < {{ rule.min }}) |
    (F.col("{{ rule.column }}") > {{ rule.max }})
).count()
if _out_of_range > 0:
    fail(f"value_between: '{{ rule.column }}' has {_out_of_range:,} out-of-range values in {FQN}")
else:
    ok(f"value_between: '{{ rule.column }}' — all values in [{{ rule.min }}, {{ rule.max }}]")

{% elif rule.type == "freshness_within" %}
# ── freshness_within: {{ rule.column }} < {{ rule.hours }}h ───
from datetime import datetime, timedelta, timezone
_cutoff = datetime.now(timezone.utc) - timedelta(hours={{ rule.hours }})
_stale = df.filter(F.col("{{ rule.column }}") < F.lit(_cutoff)).count()
if _stale == row_count and row_count > 0:
    fail(f"freshness_within: all rows in {FQN} are older than {{ rule.hours }}h")
else:
    ok(f"freshness_within: '{{ rule.column }}' — data is fresh (within {{ rule.hours }}h)")

{% endif %}
{% endfor %}

# ── Summary ────────────────────────────────────────────────────────────────────
print(f"\n{'='*60}")
if failures:
    print(f"FAILED: {len(failures)} check(s) failed in {FQN}")
    for f in failures:
        print(f"  - {f}")
    sys.exit(1)
else:
    print(f"PASSED: all checks for {FQN}")
    sys.exit(0)
