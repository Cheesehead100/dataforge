{#
  quality/databricks_jobs.tf.j2 — Databricks scheduled jobs for data quality checks.
  Provisions: one databricks_job per check in the checks list; each job runs a
  PySpark quality script from DBFS on a spot cluster.
  Context vars: checks (list with layer, table, safe_table, schedule_cron),
  product_name, catalog, env.
  Env logic: pause_status = PAUSED in non-prod environments; only prod runs
  quality checks on schedule automatically.
  Constraint: Quality check scripts must be uploaded to DBFS at
  dbfs:/dataforge/quality/ before jobs can run (Ansible playbook does this);
  databricks_runtime and databricks_node_type variables must be set in tfvars.
#}
# ── Data Quality Jobs: {{ product_name }} ────────────────────────────────────
# Generated by DataForge QualityGenerator (L4)
# Each check table gets a scheduled Databricks job.
# Upload scripts to DBFS first:
#   databricks fs cp quality/ dbfs:/dataforge/quality/ --recursive

{% for check in checks %}
resource "databricks_job" "dq_{{ check.layer }}_{{ check.safe_table }}" {
  name = "dq-{{ product_name }}-{{ check.layer }}-{{ check.table }}-${var.environment}"

  task {
    task_key = "run_quality_checks"

    spark_python_task {
      python_file = "dbfs:/dataforge/quality/{{ check.layer }}_{{ check.safe_table }}_checks.py"
      parameters  = [
        "--catalog", "{{ catalog }}",
        "--layer",   "{{ check.layer }}",
        "--table",   "{{ check.table }}",
        "--env",     var.environment,
      ]
    }

    new_cluster {
      num_workers   = 2
      spark_version = var.databricks_runtime
      node_type_id  = var.databricks_node_type

      azure_attributes {
        availability       = "SPOT_WITH_FALLBACK_AZURE"
        spot_bid_max_price = -1
      }

      spark_conf = {
        "spark.databricks.delta.preview.enabled" = "true"
      }
    }
  }

  schedule {
    quartz_cron_expression = "{{ check.schedule_cron | default('0 0 6 * * ?') }}"
    timezone_id            = "UTC"
    pause_status           = var.environment == "prod" ? "UNPAUSED" : "PAUSED"
  }

  max_retries               = 1
  min_retry_interval_millis = 300000
  timeout_seconds           = 3600

  email_notifications {
    on_failure = [var.alert_email]
  }

  tags = merge(var.tags, {
    layer   = "{{ check.layer }}"
    table   = "{{ check.table }}"
    purpose = "data-quality"
  })
}

output "dq_job_id_{{ check.layer }}_{{ check.safe_table }}" {
  value       = databricks_job.dq_{{ check.layer }}_{{ check.safe_table }}.id
  description = "Job ID for {{ check.layer }}.{{ check.table }} quality checks"
}

{% endfor %}

variable "alert_email" {
  type        = string
  description = "Email address for job failure alerts"
  default     = ""
}
