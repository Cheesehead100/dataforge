#!/usr/bin/env python3
"""
DataForge Cost Optimization Analyser — {{ product_name }}
Generated by DataForge CostOptimizationGenerator (L9)

Queries Azure Monitor for Databricks cluster utilisation over the last 30 days,
compares against configured cluster size, and outputs rightsizing recommendations.

Requirements:
  pip install azure-monitor-query azure-identity azure-mgmt-costmanagement rich

Usage:
  python scripts/analyze_costs.py \\
    --subscription-id $ARM_SUBSCRIPTION_ID \\
    --resource-group {{ metadata.resource_group }} \\
    --product {{ product_name }} \\
    --env {{ env }} \\
    [--output recommendations.json]
"""

from __future__ import annotations

import argparse
import json
import sys
from datetime import datetime, timedelta, timezone
from pathlib import Path


def _parse_args() -> argparse.Namespace:
    p = argparse.ArgumentParser(description="DataForge cost optimisation analyser")
    p.add_argument("--subscription-id", required=True)
    p.add_argument("--resource-group",  required=True)
    p.add_argument("--product",         default="{{ product_name }}")
    p.add_argument("--env",             default="{{ env }}")
    p.add_argument("--output",          default=None, help="Write JSON recommendations to file")
    p.add_argument("--dry-run",         action="store_true", help="Print without making API calls")
    return p.parse_args()


def _fetch_cluster_metrics(subscription_id: str, resource_group: str) -> list[dict]:
    """Query Azure Monitor for Databricks cluster CPU/memory over last 30 days."""
    try:
        from azure.identity import DefaultAzureCredential
        from azure.monitor.query import MetricsQueryClient, MetricAggregationType
    except ImportError:
        print("WARNING: azure-monitor-query not installed — returning mock data", file=sys.stderr)
        return _mock_metrics()

    end   = datetime.now(timezone.utc)
    start = end - timedelta(days=30)
    credential = DefaultAzureCredential()
    client = MetricsQueryClient(credential)

    # Databricks workspace resource ID pattern
    workspace_resource = (
        f"/subscriptions/{subscription_id}/resourceGroups/{resource_group}"
        f"/providers/Microsoft.Databricks/workspaces/dbw-{{ app }}-{resource_group.split('-')[-1]}"
    )

    try:
        result = client.query_resource(
            workspace_resource,
            metric_names=["DBUConsumed"],
            timespan=(start, end),
            granularity=timedelta(hours=1),
            aggregations=[MetricAggregationType.AVERAGE, MetricAggregationType.MAXIMUM],
        )
        metrics = []
        for metric in result.metrics:
            for ts in metric.timeseries:
                for dp in ts.data:
                    if dp.average is not None:
                        metrics.append({
                            "timestamp": dp.timestamp.isoformat(),
                            "avg_dbu": dp.average,
                            "max_dbu": dp.maximum or dp.average,
                        })
        return metrics
    except Exception as exc:
        print(f"WARNING: Could not fetch metrics: {exc}", file=sys.stderr)
        return _mock_metrics()


def _mock_metrics() -> list[dict]:
    """Return synthetic low-utilisation data for dry-run / CI testing."""
    import random
    now = datetime.now(timezone.utc)
    return [
        {
            "timestamp": (now - timedelta(hours=i)).isoformat(),
            "avg_dbu": random.uniform(0.05, 0.15),  # low utilisation
            "max_dbu": random.uniform(0.15, 0.30),
        }
        for i in range(720)  # 30 days × 24 hours
    ]


def _fetch_actual_cost(subscription_id: str, resource_group: str) -> float:
    """Return last-30-day actual spend for the resource group (USD)."""
    try:
        from azure.identity import DefaultAzureCredential
        from azure.mgmt.costmanagement import CostManagementClient
        from azure.mgmt.costmanagement.models import (
            QueryDefinition, TimeframeType, QueryTimePeriod,
            QueryDataset, QueryAggregation, QueryGrouping,
        )
    except ImportError:
        return 0.0

    credential = DefaultAzureCredential()
    client = CostManagementClient(credential)
    scope = f"/subscriptions/{subscription_id}/resourceGroups/{resource_group}"
    end   = datetime.now(timezone.utc)
    start = end - timedelta(days=30)

    try:
        result = client.query.usage(
            scope=scope,
            parameters=QueryDefinition(
                type="ActualCost",
                timeframe=TimeframeType.CUSTOM,
                time_period=QueryTimePeriod(from_property=start, to=end),
                dataset=QueryDataset(
                    granularity="None",
                    aggregation={"totalCost": QueryAggregation(name="Cost", function="Sum")},
                ),
            ),
        )
        rows = result.rows or []
        return float(rows[0][0]) if rows else 0.0
    except Exception:
        return 0.0


def _analyse(metrics: list[dict], max_workers: int, node_type: str, actual_cost: float) -> dict:
    if not metrics:
        return {"status": "no_data", "recommendations": []}

    avg_dbus = [m["avg_dbu"] for m in metrics]
    overall_avg = sum(avg_dbus) / len(avg_dbus)
    overall_max = max(m["max_dbu"] for m in metrics)

    # Estimate utilisation as fraction of max capacity
    estimated_utilisation_pct = min(100.0, (overall_avg / max(overall_max, 0.01)) * 100)

    recommendations = []

    # Downsize recommendation
    if estimated_utilisation_pct < {{ thresholds.cpu_low_pct }} and max_workers > 2:
        recommended_workers = max(2, int(max_workers * estimated_utilisation_pct / 100) + 1)
        estimated_savings = actual_cost * (1 - recommended_workers / max_workers) * 0.7
        if estimated_savings >= {{ thresholds.savings_threshold_usd }}:
            recommendations.append({
                "type":   "downsize_cluster",
                "priority": "high" if estimated_savings > 200 else "medium",
                "current":  f"{max_workers} workers ({node_type})",
                "recommended": f"{recommended_workers} workers ({node_type})",
                "estimated_monthly_savings_usd": round(estimated_savings, 2),
                "action": (
                    f"Update data-product.yaml: compute.databricks.autoscale.max_workers: {recommended_workers}\n"
                    f"Then re-run: dataforge generate --from data-product.yaml"
                ),
            })

    # Spot instance recommendation
    recommendations.append({
        "type":   "enable_spot",
        "priority": "low",
        "current":  "on-demand (if spot_enabled: false)",
        "recommended": "spot_enabled: true",
        "estimated_monthly_savings_usd": round(actual_cost * 0.6, 2),
        "action": "Update data-product.yaml: compute.databricks.spot_enabled: true",
    })

    # Auto-termination reminder
    recommendations.append({
        "type":   "verify_auto_termination",
        "priority": "medium",
        "description": "Confirm auto-termination is set to ≤ 30 min idle to prevent cluster runaway",
        "action": "ansible-playbook -i ansible/inventory.yml ansible/playbooks/configure_databricks.yml",
    })

    return {
        "status": "analysed",
        "product": "{{ product_name }}",
        "environment": "{{ env }}",
        "analysed_at": datetime.now(timezone.utc).isoformat(),
        "cluster": {
            "max_workers": max_workers,
            "node_type":   node_type,
            "avg_utilisation_pct": round(estimated_utilisation_pct, 1),
            "max_utilisation_pct": round(min(100, overall_max * 100), 1),
        },
        "cost": {
            "last_30_days_usd": round(actual_cost, 2),
            "monthly_budget_usd": {{ monthly_budget_usd }},
            "budget_utilisation_pct": round(100 * actual_cost / max({{ monthly_budget_usd }}, 1), 1),
        },
        "recommendations": sorted(
            recommendations,
            key=lambda r: {"high": 0, "medium": 1, "low": 2}.get(r.get("priority", "low"), 2),
        ),
    }


def _print_report(report: dict) -> None:
    try:
        from rich.console import Console
        from rich.table import Table
        console = Console()
    except ImportError:
        print(json.dumps(report, indent=2))
        return

    console.print(f"\n[bold]Cost Optimisation Report — {report['product']} ({report['environment']})[/bold]")

    c = report.get("cost", {})
    console.print(
        f"Last 30 days: [yellow]${c.get('last_30_days_usd', 0):,.2f}[/yellow] / "
        f"[cyan]${c.get('monthly_budget_usd', 0):,}[/cyan] budget "
        f"({c.get('budget_utilisation_pct', 0):.1f}%)"
    )

    recs = report.get("recommendations", [])
    if not recs:
        console.print("[green]No actionable recommendations.[/green]")
        return

    table = Table(title="Recommendations", show_lines=True)
    table.add_column("Priority", style="bold", width=8)
    table.add_column("Type",     width=25)
    table.add_column("Savings/month", width=16)
    table.add_column("Action",   width=60)

    priority_colour = {"high": "red", "medium": "yellow", "low": "green"}
    for rec in recs:
        pri  = rec.get("priority", "low")
        savings = f"${rec['estimated_monthly_savings_usd']:,.0f}" if "estimated_monthly_savings_usd" in rec else "—"
        table.add_row(
            f"[{priority_colour.get(pri, 'white')}]{pri.upper()}[/]",
            rec.get("type", ""),
            savings,
            rec.get("action", rec.get("description", "")),
        )

    console.print(table)


def main() -> None:
    args = _parse_args()

    if args.dry_run:
        metrics = _mock_metrics()
        actual_cost = 342.0  # synthetic
    else:
        metrics = _fetch_cluster_metrics(args.subscription_id, args.resource_group)
        actual_cost = _fetch_actual_cost(args.subscription_id, args.resource_group)

    report = _analyse(metrics, {{ max_workers }}, "{{ node_type }}", actual_cost)
    _print_report(report)

    if args.output:
        Path(args.output).write_text(json.dumps(report, indent=2), encoding="utf-8")
        print(f"\nReport written to {args.output}")

    high_priority = [r for r in report.get("recommendations", []) if r.get("priority") == "high"]
    if high_priority:
        sys.exit(2)   # non-zero signals CI to surface in PR comment


if __name__ == "__main__":
    main()
