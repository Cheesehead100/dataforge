{#
  cost/github_actions_cost.yml.j2 — GitHub Actions weekly cost optimisation workflow.
  Runs analyze_costs.py every Monday 06:00 UTC; posts summary to job summary and
  automatically opens a GitHub issue when high-priority recommendations are found.
  Context vars: product_name, env, metadata.
  Env logic: none — workflow targets a single environment per instantiation.
  Constraint: issues: write permission is required for the auto-open-issue step;
  ARM secrets must be stored in the GitHub environment named after env.
#}
# DataForge Cost Optimization — {{ product_name }}
# Generated by DataForge CostOptimizationGenerator (L9)
# Weekly analysis of cluster utilisation vs budget — surfaces rightsizing recommendations.

name: "Cost Optimization — {{ product_name }}"

on:
  schedule:
    - cron: "0 6 * * 1"   # every Monday 06:00 UTC
  workflow_dispatch:

permissions:
  contents: read
  id-token: write
  issues: write   # for creating recommendation issues

jobs:
  cost-analysis:
    name: "Analyse costs — {{ product_name }} ({{ env }})"
    runs-on: ubuntu-latest
    environment: {{ env }}

    env:
      ARM_CLIENT_ID: {% raw %}${{ secrets.ARM_CLIENT_ID }}{% endraw %}

      ARM_CLIENT_SECRET: {% raw %}${{ secrets.ARM_CLIENT_SECRET }}{% endraw %}

      ARM_TENANT_ID: {% raw %}${{ secrets.ARM_TENANT_ID }}{% endraw %}

      ARM_SUBSCRIPTION_ID: {% raw %}${{ secrets.ARM_SUBSCRIPTION_ID }}{% endraw %}


    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Setup Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.11"

      - name: Install dependencies
        run: |
          pip install -q \
            azure-identity \
            azure-monitor-query \
            azure-mgmt-costmanagement \
            rich

      - name: Run cost analysis
        id: analysis
        run: |
          set +e
          python scripts/analyze_costs.py \
            --subscription-id "{% raw %}${{ secrets.ARM_SUBSCRIPTION_ID }}{% endraw %}" \
            --resource-group "{{ metadata.resource_group }}" \
            --product "{{ product_name }}" \
            --env "{{ env }}" \
            --output /tmp/cost_report.json
          EXIT_CODE=$?
          echo "exitcode=${EXIT_CODE}" >> $GITHUB_OUTPUT

          # Add report summary to job summary
          echo "## Cost Optimisation Report — {{ product_name }} ({{ env }})" >> $GITHUB_STEP_SUMMARY
          echo "" >> $GITHUB_STEP_SUMMARY
          if [ -f /tmp/cost_report.json ]; then
            python -c "
          import json, sys
          r = json.load(open('/tmp/cost_report.json'))
          c = r.get('cost', {})
          print(f'**Last 30 days:** \${c.get(\"last_30_days_usd\", 0):,.2f} / \${c.get(\"monthly_budget_usd\", 0):,} budget ({c.get(\"budget_utilisation_pct\", 0):.1f}%)')
          print()
          recs = r.get('recommendations', [])
          if recs:
              print('### Recommendations')
              for rec in recs:
                  pri = rec.get('priority', 'low').upper()
                  savings = f\"\${rec['estimated_monthly_savings_usd']:,.0f}/mo\" if 'estimated_monthly_savings_usd' in rec else ''
                  print(f'- **[{pri}]** {rec[\"type\"]} {savings}')
                  print(f'  {rec.get(\"action\", rec.get(\"description\", \"\"))[:120]}')
          else:
              print('No actionable recommendations this week.')
          " >> $GITHUB_STEP_SUMMARY
          fi
          exit ${EXIT_CODE}
        continue-on-error: true

      - name: Open GitHub issue for high-priority recommendations
        if: {% raw %}${{ steps.analysis.outputs.exitcode == '2' }}{% endraw %}

        uses: actions/github-script@v7
        with:
          script: |
            const fs = require('fs');
            const report = JSON.parse(fs.readFileSync('/tmp/cost_report.json', 'utf8'));
            const high = report.recommendations.filter(r => r.priority === 'high');
            if (!high.length) return;

            const body = [
              `## Cost Optimisation — {{ product_name }} ({{ env }})`,
              ``,
              `**Last 30 days:** $${report.cost.last_30_days_usd?.toLocaleString()} / $${report.cost.monthly_budget_usd?.toLocaleString()} budget`,
              ``,
              `### High-Priority Recommendations`,
              ...high.map(r => [
                `#### ${r.type}`,
                `- **Current:** ${r.current || 'N/A'}`,
                `- **Recommended:** ${r.recommended || 'N/A'}`,
                `- **Estimated savings:** $${r.estimated_monthly_savings_usd?.toLocaleString()}/month`,
                `- **Action:** \`${r.action}\``,
              ].join('\n')),
              ``,
              `_Generated by DataForge Cost Optimisation — [Run #${context.runId}](${context.serverUrl}/${context.repo.owner}/${context.repo.repo}/actions/runs/${context.runId})_`,
            ].join('\n');

            await github.rest.issues.create({
              owner: context.repo.owner,
              repo: context.repo.repo,
              title: `⚡ Cost optimisation: {{ product_name }} ({{ env }}) — high-priority recommendations`,
              body,
              labels: ['cost-optimisation', 'platform', '{{ env }}'],
            });
