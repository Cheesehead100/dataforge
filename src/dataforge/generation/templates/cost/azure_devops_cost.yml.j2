# DataForge Cost Optimization — {{ product_name }}
# Generated by DataForge CostOptimizationGenerator (L9)

trigger: none

schedules:
  - cron: "0 6 * * 1"    # every Monday 06:00 UTC
    displayName: "Weekly cost analysis ({{ env }})"
    branches:
      include: [main]
    always: true

variables:
  - name: PRODUCT
    value: "{{ product_name }}"
  - name: ENV
    value: "{{ env }}"
  - name: RESOURCE_GROUP
    value: "{{ metadata.resource_group }}"
  - group: "dataforge-{{ env }}-secrets"

stages:
  - stage: CostAnalysis
    displayName: "Cost Optimisation — {{ product_name }} ({{ env }})"
    jobs:
      - job: Analyse
        displayName: "Analyse costs"
        pool:
          vmImage: ubuntu-latest
        steps:
          - checkout: self

          - task: UsePythonVersion@0
            inputs:
              versionSpec: "3.11"

          - bash: |
              pip install -q azure-identity azure-monitor-query azure-mgmt-costmanagement rich
            displayName: "Install dependencies"

          - bash: |
              set +e
              python scripts/analyze_costs.py \
                --subscription-id "$(ARM_SUBSCRIPTION_ID)" \
                --resource-group "$(RESOURCE_GROUP)" \
                --product "$(PRODUCT)" \
                --env "$(ENV)" \
                --output "$(Agent.TempDirectory)/cost_report.json"
              EXIT_CODE=$?
              echo "##vso[task.setvariable variable=COST_EXIT_CODE]${EXIT_CODE}"
              if [ "${EXIT_CODE}" = "2" ]; then
                echo "##vso[task.logissue type=warning]High-priority cost recommendations detected for $(PRODUCT) ($(ENV)). Review cost_report.json."
              fi
              exit 0  # don't fail the build; open work item instead
            displayName: "Run cost analysis"
            env:
              AZURE_CLIENT_ID: $(ARM_CLIENT_ID)
              AZURE_CLIENT_SECRET: $(ARM_CLIENT_SECRET)
              AZURE_TENANT_ID: $(ARM_TENANT_ID)
              ARM_SUBSCRIPTION_ID: $(ARM_SUBSCRIPTION_ID)

          - bash: |
              echo "## Cost Analysis Results" >> $GITHUB_STEP_SUMMARY
              cat "$(Agent.TempDirectory)/cost_report.json"
            displayName: "Print report"
            condition: always()

          - task: PublishBuildArtifacts@1
            displayName: "Publish cost report"
            condition: always()
            inputs:
              PathtoPublish: $(Agent.TempDirectory)/cost_report.json
              ArtifactName: cost-report
