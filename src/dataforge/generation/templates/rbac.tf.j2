{#
  rbac.tf.j2 — Azure role assignments derived from the FlowGraph edge analysis.
  Provisions: one azurerm_role_assignment per edge in rbac.assignments; uses
  principal_tf_ref() and scope_tf_ref() helpers to resolve Terraform references.
  Context vars: rbac (RbacResult with assignments, warnings, unresolved),
  principal_tf_ref(node_id), scope_tf_ref(node_id), metadata.
  Env logic: none — role assignments are environment-agnostic; SP-backed
  assignments use count=0 guard when the SP object ID variable is not yet set.
  Constraint: role_definition_id is a full ARM path so this works across subscriptions.
#}
# ============================================================
# RBAC Role Assignments
# Generated deterministically by DataForge — DO NOT EDIT.
# Source: dataforge rbac matrix v{{ metadata.application_name }}
# ============================================================
{% if rbac.warnings %}

# Warnings:
{% for w in rbac.warnings %}
# - {{ w }}
{% endfor %}
{% endif %}
{% if rbac.unresolved %}

# Unresolved edges (no RBAC rule — manual action required):
{% for key in rbac.unresolved %}
# - {{ key }}
{% endfor %}
{% endif %}

{% for ra in rbac.assignments %}
{% set pref = principal_tf_ref(ra.principal_node_id) %}
resource "azurerm_role_assignment" "{{ ra.terraform_key }}" {
  # {{ ra.rationale }}
{% if pref.startswith('var.') %}
  # skip when SP object ID not yet supplied (set after workspace creation)
  count                = {{ pref }} != "" ? 1 : 0
{% endif %}
  principal_id         = {{ pref }}
  role_definition_id   = "/subscriptions/${data.azurerm_client_config.current.subscription_id}/providers/Microsoft.Authorization/roleDefinitions/{{ ra.role_definition_id }}"
  scope                = {{ scope_tf_ref(ra.scope_node_id) }}
}

{% endfor %}
