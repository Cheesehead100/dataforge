{#
  sql_mi.tf.j2 — Azure SQL Managed Instance per SQL MI node.
  Provisions: azurerm_mssql_managed_instance (GP_Gen5, 4 vCores, 32 GB) with
  SystemAssigned managed identity.
  Context vars: sql_mi_nodes.
  Env logic: none — instance size is fixed at generation time.
  Constraint: The target subnet (var.sql_mi_subnet_id) must be dedicated to SQL MI
  with Microsoft.Sql/managedInstances delegation — no other resources can share it.
  Managed Identity logins must be created via T-SQL after provisioning (see inline
  comments); these cannot be expressed as Terraform resources.
#}
{% for node in sql_mi_nodes %}
# SQL Managed Instance — subnet must be dedicated to SQL MI
resource "azurerm_mssql_managed_instance" "{{ node.id }}" {
  name                         = "sqlmi-${var.application_name}-${var.environment}"
  resource_group_name          = var.resource_group_name
  location                     = var.location
  license_type                 = "BasePrice"
  sku_name                     = "GP_Gen5"
  storage_size_in_gb           = 32
  subnet_id                    = var.sql_mi_subnet_id
  vcores                       = 4
  tags                         = var.tags

  identity {
    type = "SystemAssigned"
  }

  # Data-plane logins for Managed Identities (can't be expressed in RBAC):
  # For each pipeline identity that reads/writes this SQL MI, run:
  #   CREATE USER [<resource-name>] FROM EXTERNAL PROVIDER;
  #   ALTER ROLE db_datareader ADD MEMBER [<resource-name>];   -- for read
  #   ALTER ROLE db_datawriter ADD MEMBER [<resource-name>];   -- for write
  # See sql_mi_logins.md for generated instructions.
}

{% endfor %}
