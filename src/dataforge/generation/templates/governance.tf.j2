# ── Unity Catalog: {{ catalog }} ─────────────────────────────────────────────
# Generated by DataForge GovernanceGenerator (L3)

resource "databricks_catalog" "{{ app }}" {
  name    = "{{ catalog }}"
  comment = "{{ product_name }} catalog — managed by DataForge"
}

{% for schema in schemas %}
resource "databricks_schema" "{{ app }}_{{ schema }}" {
  catalog_name = databricks_catalog.{{ app }}.name
  name         = "{{ schema }}"
}

{% endfor %}
{% for grant in normalized_grants %}
resource "databricks_grants" "{{ app }}_{{ grant.resource_id }}" {
{% if grant.scope == "catalog" %}
  catalog = databricks_catalog.{{ app }}.name
{% else %}
  schema = "${databricks_catalog.{{ app }}.name}.{{ grant.schema }}"
{% endif %}
  grant {
    principal  = "{{ grant.principal }}"
    privileges = {{ grant.privileges | tojson }}
  }
}

{% endfor %}
{% if lineage %}
# Lineage tracking enabled — configure Delta Sharing in Unity Catalog workspace settings
{% endif %}
{% if audit %}
# Audit logging enabled — route to Log Analytics via Azure Monitor diagnostic settings on Databricks workspace
{% endif %}

variable "unity_metastore_id" {
  type        = string
  description = "ID of an existing Unity Catalog metastore (leave empty to skip metastore assignment)"
  default     = "{{ metastore_name }}"
}
