{% for node in aks_nodes %}
# ── AKS cluster: {{ node.name }} ──────────────────────────────────────────────

resource "azurerm_user_assigned_identity" "{{ node.id }}_workload" {
  name                = "id-${var.application_name}-${var.environment}-workload"
  resource_group_name = var.resource_group_name
  location            = var.location
  tags                = var.tags
}

resource "azurerm_kubernetes_cluster" "{{ node.id }}" {
  name                = "aks-${var.application_name}-${var.environment}"
  location            = var.location
  resource_group_name = var.resource_group_name
  dns_prefix          = "${var.application_name}-${var.environment}"
  tags                = var.tags

  default_node_pool {
    name       = "system"
    node_count = 2
    vm_size    = "Standard_D4s_v7"

    upgrade_settings {
      max_surge = "10%"
    }
  }

  identity {
    type = "SystemAssigned"
  }

  network_profile {
    network_plugin = "azure"
    network_policy = "azure"
  }

  oidc_issuer_enabled       = true
  workload_identity_enabled = true
}

resource "azurerm_kubernetes_cluster_node_pool" "{{ node.id }}_spark" {
  name                  = "spark"
  kubernetes_cluster_id = azurerm_kubernetes_cluster.{{ node.id }}.id
  vm_size               = "Standard_E8s_v7"
  node_count            = 2
  tags                  = var.tags

  node_labels = {
    "workload" = "spark"
  }

  upgrade_settings {
    max_surge = "10%"
  }
}

# Federated credential: lets the Kubernetes ServiceAccount acquire tokens as the UAMI.
# The Spark pods must be annotated with:
#   azure.workload.identity/client-id: <workload_client_id output>
resource "azurerm_federated_identity_credential" "{{ node.id }}_workload" {
  name                = "fic-${var.application_name}-${var.environment}-spark"
  resource_group_name = var.resource_group_name
  parent_id           = azurerm_user_assigned_identity.{{ node.id }}_workload.id
  audience            = ["api://AzureADTokenExchange"]
  issuer              = azurerm_kubernetes_cluster.{{ node.id }}.oidc_issuer_url
  subject             = "system:serviceaccount:${var.{{ node.id }}_workload_namespace}:${var.{{ node.id }}_workload_service_account}"
}

{% endfor %}
