# azure-pipelines.yml — Generated by DataForge for {{ app_name }} ({{ env }})
# Stages: Validate -> Plan (all PRs) -> Apply (main branch only)
#
# Required pipeline variables (set in ADO Library / variable group):
#   ARM_SERVICE_CONNECTION  — Azure DevOps service connection name with Contributor on the target RG
#   TF_BACKEND_RG           — Resource group containing the TF state storage account
#   TF_BACKEND_SA           — Storage account name for TF state
#   TF_STATE_KEY            — State blob key, e.g. {{ app_name }}-{{ env }}.tfstate
#
# After first deploy you can restrict ARM_SERVICE_CONNECTION to the minimum roles
# listed in rbac.tf instead of Contributor.

trigger:
  branches:
    include:
      - main
  paths:
    include:
      - "**/*.tf"
      - "**/*.tfvars"
      - "azure-pipelines.yml"

pr:
  branches:
    include:
      - "*"
  paths:
    include:
      - "**/*.tf"
      - "**/*.tfvars"

variables:
  TF_VERSION: "1.7.5"
  TF_ENVIRONMENT: "{{ env }}"

pool:
  vmImage: ubuntu-latest

stages:
  # ── Stage 1: Static validation ────────────────────────────────────────────
  - stage: Validate
    displayName: "Validate & Lint"
    jobs:
      - job: TerraformValidate
        displayName: "terraform validate + fmt"
        steps:
          - task: TerraformInstaller@1
            displayName: "Install Terraform $(TF_VERSION)"
            inputs:
              terraformVersion: $(TF_VERSION)

          - script: terraform init -backend=false
            displayName: "Init (no backend)"

          - script: terraform validate
            displayName: "Validate"

          - script: terraform fmt -check -recursive
            displayName: "Format check"

      - job: CheckovScan
        displayName: "Checkov security scan"
        steps:
          - script: pip install checkov
            displayName: "Install Checkov"

          - script: checkov -d . --framework terraform --soft-fail
            displayName: "Checkov scan"

  # ── Stage 2: Plan (all PRs and main) ──────────────────────────────────────
  - stage: Plan
    displayName: "Terraform Plan"
    dependsOn: Validate
    condition: succeeded()
    jobs:
      - job: TerraformPlan
        displayName: "terraform plan"
        steps:
          - task: TerraformInstaller@1
            displayName: "Install Terraform $(TF_VERSION)"
            inputs:
              terraformVersion: $(TF_VERSION)

          - task: TerraformTaskV4@4
            displayName: "terraform init"
            inputs:
              provider: azurerm
              command: init
              backendServiceArm: "$(ARM_SERVICE_CONNECTION)"
              backendAzureRmResourceGroupName: "$(TF_BACKEND_RG)"
              backendAzureRmStorageAccountName: "$(TF_BACKEND_SA)"
              backendAzureRmContainerName: "tfstate"
              backendAzureRmKey: "$(TF_STATE_KEY)"

          - task: TerraformTaskV4@4
            displayName: "terraform plan"
            inputs:
              provider: azurerm
              command: plan
              environmentServiceNameAzureRM: "$(ARM_SERVICE_CONNECTION)"
              commandOptions: "-out=tfplan"

          - publish: tfplan
            artifact: tfplan
            displayName: "Publish plan artifact"

  # ── Stage 3: Apply (main branch only) ────────────────────────────────────
  - stage: Apply
    displayName: "Terraform Apply"
    dependsOn: Plan
    condition: >
      and(
        succeeded(),
        eq(variables['Build.SourceBranch'], 'refs/heads/main')
      )
    jobs:
      - deployment: TerraformApply
        displayName: "terraform apply"
        environment: "$(TF_ENVIRONMENT)"
        strategy:
          runOnce:
            deploy:
              steps:
                - checkout: self

                - download: current
                  artifact: tfplan
                  displayName: "Download plan artifact"

                - task: TerraformInstaller@1
                  displayName: "Install Terraform $(TF_VERSION)"
                  inputs:
                    terraformVersion: $(TF_VERSION)

                - task: TerraformTaskV4@4
                  displayName: "terraform init"
                  inputs:
                    provider: azurerm
                    command: init
                    backendServiceArm: "$(ARM_SERVICE_CONNECTION)"
                    backendAzureRmResourceGroupName: "$(TF_BACKEND_RG)"
                    backendAzureRmStorageAccountName: "$(TF_BACKEND_SA)"
                    backendAzureRmContainerName: "tfstate"
                    backendAzureRmKey: "$(TF_STATE_KEY)"

                - task: TerraformTaskV4@4
                  displayName: "terraform apply"
                  inputs:
                    provider: azurerm
                    command: apply
                    environmentServiceNameAzureRM: "$(ARM_SERVICE_CONNECTION)"
                    commandOptions: "$(Pipeline.Workspace)/tfplan/tfplan"
{% if aks_nodes %}

# NOTE: After apply, configure kubectl access:
#   az aks get-credentials --resource-group {{ resource_group }} --name aks-{{ app_name }}-{{ env }}
#
# Then label your Spark ServiceAccount for Workload Identity:
#   kubectl annotate sa spark-sa -n spark \
#     azure.workload.identity/client-id=<workload_client_id output>
{% endif %}
{% if databricks_nodes %}

# NOTE: After apply, supply Databricks SP object IDs in terraform.tfvars:
{% for node in databricks_nodes %}
#   {{ node.id }}_sp_object_id = "<object-id>"
{% endfor %}
{% endif %}
