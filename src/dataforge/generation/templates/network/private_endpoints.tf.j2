{#
  network/private_endpoints.tf.j2 — Private endpoints and storage firewall lockdown.
  Provisions: azurerm_private_endpoint per service in pe_specs (with DNS zone group),
  and azurerm_storage_account_network_rules to lock ADLS firewall after endpoints exist.
  Context vars: pe_specs (list with display_name, safe_name, resource_id_ref,
  sub_resource, primary_dns_zone_ref), adls_nodes, has_adls, has_databricks.
  Env logic: none — all services get private endpoints regardless of environment.
  Constraint: depends_on the DNS zone VNet links (from dns.tf) to ensure A records
  register correctly; storage network rules must be applied AFTER private endpoints
  or the storage firewall will block Terraform container creation (see sequencing.sh).
#}
# ── Private Endpoints — {{ product_name }} ────────────────────────────────────
# Generated by DataForge NetworkingGenerator
#
# Every Azure service in this data product gets a private endpoint in the
# dedicated PE subnet. Traffic never traverses the public internet.
#
# WHY depends_on matters:
#   The private_dns_zone_group block inside each endpoint creates DNS A records
#   inside the zone. If the zone VNet link doesn't exist yet, the A record
#   registration silently fails and DNS resolution inside the VNet breaks.
#   We express this via depends_on to make Terraform serialize correctly.

{% for svc in pe_specs %}
# ── {{ svc.display_name }} ──────────────────────────────────────────────────

resource "azurerm_private_endpoint" "{{ svc.safe_name }}" {
  name                = "pe-{{ svc.safe_name | replace('_', '-') }}-${var.application_name}-${var.environment}"
  resource_group_name = var.resource_group_name
  location            = var.location
  subnet_id           = azurerm_subnet.private_endpoints.id
  tags                = var.tags

  private_service_connection {
    name                           = "psc-{{ svc.safe_name | replace('_', '-') }}-${var.application_name}"
    private_connection_resource_id = {{ svc.resource_id_ref }}
    is_manual_connection           = false
    subresource_names              = ["{{ svc.sub_resource }}"]
  }

  private_dns_zone_group {
    name                 = "pdns-{{ svc.safe_name }}"
    private_dns_zone_ids = [azurerm_private_dns_zone.{{ svc.primary_dns_zone_ref }}.id]
  }

  depends_on = [
    azurerm_private_dns_zone_virtual_network_link.{{ svc.primary_dns_zone_ref }},
  ]
}

{% endfor %}

{% if has_adls %}
# ── Storage account network rules ─────────────────────────────────────────────
#
# This resource REPLACES the inline network_rules block in storage.tf.
# It must be applied AFTER the private endpoints exist — Terraform enforces
# this via the depends_on list below.
#
# IMPORTANT: Remove or comment out the inline `network_rules {}` block from
# storage.tf before running terraform apply, otherwise the provider will report
# a conflict between the inline block and this resource.

{% for node in adls_nodes %}
resource "azurerm_storage_account_network_rules" "{{ node.safe_id }}" {
  storage_account_id = azurerm_storage_account.{{ node.id }}.id
  default_action     = "Deny"
  bypass             = ["AzureServices"]

  virtual_network_subnet_ids = [
    azurerm_subnet.private_endpoints.id,
{% if has_databricks %}
    azurerm_subnet.dbw_private.id,
    azurerm_subnet.dbw_public.id,
{% endif %}
  ]

  # Enforce network rules only AFTER private endpoints are attached.
  # Without this, the storage firewall denies container creation (Pain Point 2).
  depends_on = [
    azurerm_private_endpoint.adls_{{ node.safe_id }}_blob,
    azurerm_private_endpoint.adls_{{ node.safe_id }}_dfs,
  ]
}
{% endfor %}
{% endif %}
