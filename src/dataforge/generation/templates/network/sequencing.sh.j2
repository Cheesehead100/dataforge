{#
  network/sequencing.sh.j2 — Staged terraform apply script for private-endpoint stacks.
  Purpose: solves the ordering problem where a naive `terraform apply` fails because
  the storage firewall blocks container creation before private endpoints exist.
  Runs 6 targeted apply stages: (1) VNet+NSGs, (2) DNS zones, (3) core infra with
  firewall open, (4) storage containers, (5) private endpoints + firewall lockdown,
  (6) full idempotent apply.
  Context vars: product_name, env, dns_zones, adls_nodes, pe_specs,
  has_adls, has_key_vault, has_databricks.
  Env logic: none — all environments with private endpoints need this script.
  Constraint: Must be run from the generated Terraform output directory; requires
  ARM_* credentials set and terraform init already completed.
#}
#!/usr/bin/env bash
# ── Deployment Sequencing — {{ product_name }} ────────────────────────────────
# Generated by DataForge NetworkingGenerator
#
# WHY this script exists (Pain Point 2 — Private Endpoint Hell):
#
#   A naive `terraform apply` on a private-endpoint environment fails mid-run
#   because Terraform tries to create storage containers before the storage
#   firewall is open. Azure blocks the container creation with 403 Forbidden.
#
#   The correct order is:
#
#   Stage 1: Network foundation (VNet, subnets, NSGs)
#   Stage 2: Private DNS zones + VNet links
#   Stage 3: Core infrastructure (storage account, key vault, databricks, ADF)
#            — at this point the firewall is still OPEN (default_action=Allow)
#   Stage 4: Storage containers and data-plane bootstrap
#   Stage 5: Private endpoints + storage firewall lock-down (default_action=Deny)
#   Stage 6: Full apply (idempotent; resolves any remaining diff)
#
# Run this script instead of bare `terraform apply` in private-endpoint environments.
#
# Prerequisites:
#   - ARM_CLIENT_ID, ARM_CLIENT_SECRET, ARM_TENANT_ID, ARM_SUBSCRIPTION_ID set
#   - terraform init already run
#   - Logged in: az login --service-principal -u $ARM_CLIENT_ID -p $ARM_CLIENT_SECRET --tenant $ARM_TENANT_ID

set -euo pipefail

TF_DIR="${1:-output}"
ENV="{{ env }}"

echo "═══════════════════════════════════════════════════════════════"
echo "  DataForge Staged Deployment — {{ product_name }} (${ENV})"
echo "═══════════════════════════════════════════════════════════════"

cd "${TF_DIR}"

# ── Stage 1: Network foundation ───────────────────────────────────────────────
echo ""
echo "▶ Stage 1/6 — Network foundation (VNet, subnets, NSGs)"
terraform apply \
  -target=azurerm_virtual_network.dataforge \
  -target=azurerm_network_security_group.dbw_private \
  -target=azurerm_network_security_group.dbw_public \
  -target=azurerm_subnet.dbw_private \
  -target=azurerm_subnet.dbw_public \
  -target=azurerm_subnet.private_endpoints \
  -target=azurerm_subnet_network_security_group_association.dbw_private \
  -target=azurerm_subnet_network_security_group_association.dbw_public \
  -var="environment=${ENV}" \
  -auto-approve
echo "✓ Stage 1 complete"

# ── Stage 2: Private DNS zones + VNet links ───────────────────────────────────
echo ""
echo "▶ Stage 2/6 — Private DNS zones + VNet links"
{% for zone in dns_zones %}
terraform apply \
  -target=azurerm_private_dns_zone.{{ zone.safe_name }} \
  -target=azurerm_private_dns_zone_virtual_network_link.{{ zone.safe_name }} \
  -var="environment=${ENV}" \
  -auto-approve
{% endfor %}
echo "✓ Stage 2 complete"

# ── Stage 3: Core infrastructure (firewall still open) ───────────────────────
echo ""
echo "▶ Stage 3/6 — Core infrastructure (storage, key vault, workspace)"
echo "   NOTE: Storage firewall is OPEN at this stage — required for container creation"
terraform apply \
  -var="environment=${ENV}" \
  -auto-approve \
  -target=azurerm_resource_group.main \
{% if has_adls %}{% for node in adls_nodes %}  -target=azurerm_storage_account.{{ node.id }} \
{% endfor %}{% endif %}{% if has_key_vault %}  -target=azurerm_key_vault.main \
{% endif %}{% if has_databricks %}  -target=azurerm_databricks_workspace.main \
{% endif %}  -target=azurerm_log_analytics_workspace.main
echo "✓ Stage 3 complete"

# ── Stage 4: Storage containers and data-plane bootstrap ─────────────────────
echo ""
echo "▶ Stage 4/6 — Storage containers + data-plane resources"
{% if has_adls %}{% for node in adls_nodes %}
terraform apply \
  -target=azurerm_storage_data_lake_gen2_filesystem.{{ node.id }}_raw \
  -target=azurerm_storage_data_lake_gen2_filesystem.{{ node.id }}_curated \
  -var="environment=${ENV}" \
  -auto-approve
{% endfor %}{% endif %}
echo "✓ Stage 4 complete"

# ── Stage 5: Private endpoints + storage firewall ────────────────────────────
echo ""
echo "▶ Stage 5/6 — Private endpoints + storage firewall lock-down"
{% for svc in pe_specs %}
terraform apply \
  -target=azurerm_private_endpoint.{{ svc.safe_name }} \
  -var="environment=${ENV}" \
  -auto-approve
{% endfor %}
{% if has_adls %}{% for node in adls_nodes %}
# Enable storage firewall AFTER private endpoints are confirmed healthy
terraform apply \
  -target=azurerm_storage_account_network_rules.{{ node.safe_id }} \
  -var="environment=${ENV}" \
  -auto-approve
{% endfor %}{% endif %}
echo "✓ Stage 5 complete — private endpoints attached, firewall locked"

# ── Stage 6: Full apply (idempotent) ─────────────────────────────────────────
echo ""
echo "▶ Stage 6/6 — Full apply (idempotent; resolves any remaining diff)"
terraform apply \
  -var="environment=${ENV}" \
  -auto-approve
echo "✓ Stage 6 complete"

echo ""
echo "═══════════════════════════════════════════════════════════════"
echo "  ✅ Deployment complete — {{ product_name }} (${ENV})"
echo ""
echo "  Private endpoints attached:"
{% for svc in pe_specs %}
echo "    • {{ svc.display_name }}"
{% endfor %}
echo ""
echo "  Storage firewall: LOCKED (default_action=Deny)"
echo "  All traffic routes through private endpoints."
echo "═══════════════════════════════════════════════════════════════"
