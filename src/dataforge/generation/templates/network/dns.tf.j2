{#
  network/dns.tf.j2 — Private DNS zones and VNet links for each Azure service.
  Provisions: azurerm_private_dns_zone and azurerm_private_dns_zone_virtual_network_link
  per zone in dns_zones; links each zone to the shared VNet from networking.tf.
  Context vars: dns_zones (list with zone_name, safe_name), product_name,
  app_name, env.
  Env logic: none — zones are provisioned identically across environments.
  Constraint: Must be applied before network/private_endpoints.tf; the DNS zone VNet
  link must exist before the private endpoint creates DNS A records, otherwise
  DNS resolution inside the VNet silently fails.
#}
# ── Private DNS Zones — {{ product_name }} ────────────────────────────────────
# Generated by DataForge NetworkingGenerator
#
# Each private DNS zone resolves private-endpoint FQDNs within the VNet.
# The zone + VNet link must exist BEFORE private endpoints are created —
# Terraform resolves this automatically via implicit depends_on from
# azurerm_private_endpoint.*.private_dns_zone_group.
#
# Deployment order (enforced by sequencing.sh):
#   Stage 1: VNet + subnets (networking.tf)
#   Stage 2: DNS zones + VNet links  ← this file
#   Stage 3: Private endpoints       ← network/private_endpoints.tf
#   Stage 4: Storage firewall enable ← network/private_endpoints.tf (bottom)
#   Stage 5: Full terraform apply

{% for zone in dns_zones %}
# ── {{ zone.zone_name }} ─────────────────────────────────────────────────────

resource "azurerm_private_dns_zone" "{{ zone.safe_name }}" {
  name                = "{{ zone.zone_name }}"
  resource_group_name = var.resource_group_name
  tags                = var.tags
}

resource "azurerm_private_dns_zone_virtual_network_link" "{{ zone.safe_name }}" {
  name                  = "pdnslink-{{ zone.safe_name }}-${var.application_name}-${var.environment}"
  resource_group_name   = var.resource_group_name
  private_dns_zone_name = azurerm_private_dns_zone.{{ zone.safe_name }}.name
  virtual_network_id    = azurerm_virtual_network.dataforge.id
  registration_enabled  = false
  tags                  = var.tags
}

{% endfor %}
