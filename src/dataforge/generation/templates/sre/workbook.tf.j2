{#
  sre/workbook.tf.j2 — Terraform resource to deploy the Azure Monitor Workbook.
  Provisions: data.local_file (reads workbook.json from the sre/ subdirectory)
  and azurerm_application_insights_workbook.
  Context vars: product_name, env, safe_app.
  Env logic: none — dashboard is deployed in all environments.
  Constraint: workbook.json must be rendered into the sre/ subdirectory relative
  to the Terraform module root before apply; the path.module reference assumes
  standard DataForge output directory layout.
#}
# ── SRE Dashboard: {{ product_name }} ────────────────────────────────────────
# Generated by DataForge SreDashboardGenerator (L9)
# Deploys an Azure Monitor Workbook with pipeline health, freshness, cost,
# and data quality metrics for {{ product_name }} in {{ env }}.

data "local_file" "sre_workbook_json" {
  filename = "${path.module}/../sre/workbook.json"
}

resource "azurerm_application_insights_workbook" "sre_{{ safe_app }}" {
  name                = "{{ safe_app }}-sre-{{ env }}"
  resource_group_name = var.resource_group_name
  location            = var.location
  display_name        = "{{ product_name }} — Platform SRE Dashboard ({{ env }})"
  tags                = var.tags

  data_json = data.local_file.sre_workbook_json.content
}

output "sre_dashboard_url" {
  value       = "https://portal.azure.com/#@${data.azurerm_client_config.current.tenant_id}/resource${azurerm_application_insights_workbook.sre_{{ safe_app }}.id}/workbook"
  description = "Azure Portal URL for the {{ product_name }} SRE dashboard"
}
