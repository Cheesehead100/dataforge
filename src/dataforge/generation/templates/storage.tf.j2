{#
  storage.tf.j2 — ADLS Gen2 storage account + medallion filesystems per ADLS node.
  Provisions: azurerm_storage_account (HNS enabled, ZRS, StorageV2) and two
  azurerm_storage_data_lake_gen2_filesystem resources (raw, curated) per node.
  Context vars: adls_nodes, env.
  Env logic: prod locks down public_network_access and sets network_rules
  default_action="Deny"; dev/test leaves public access open so Terraform
  data-plane ops work without a private pipeline agent.
  Constraint: If network/private_endpoints.tf is included, remove the inline
  network_rules block here to avoid a provider conflict with
  azurerm_storage_account_network_rules.
#}
{% for node in adls_nodes %}
resource "azurerm_storage_account" "{{ node.id }}" {
  name                     = "st${var.application_name}${var.environment}"
  resource_group_name      = var.resource_group_name
  location                 = var.location
  account_tier             = "Standard"
  account_replication_type = "ZRS"
  account_kind             = "StorageV2"
  is_hns_enabled           = true   # ADLS Gen2 hierarchical namespace
  tags                     = var.tags

  # prod: deny all public traffic — access via private endpoints only.
  # dev/test: allow public access so Terraform data-plane ops work without a private agent.
  public_network_access_enabled        = {{ "false" if env == "prod" else "true" }}
  allow_nested_items_to_be_public      = false
  infrastructure_encryption_enabled    = true
  min_tls_version                      = "TLS1_2"

  network_rules {
    default_action = "{{ "Deny" if env == "prod" else "Allow" }}"
    bypass         = ["AzureServices"]
{% if env == "prod" %}
    # Add ip_rules or virtual_network_subnet_ids to permit your Terraform runner / pipeline agent.
    # ip_rules = ["<your-agent-ip>/32"]
{% endif %}
  }
}

resource "azurerm_storage_data_lake_gen2_filesystem" "{{ node.id }}_raw" {
  name               = "raw"
  storage_account_id = azurerm_storage_account.{{ node.id }}.id
}

resource "azurerm_storage_data_lake_gen2_filesystem" "{{ node.id }}_curated" {
  name               = "curated"
  storage_account_id = azurerm_storage_account.{{ node.id }}.id
}

{% endfor %}
