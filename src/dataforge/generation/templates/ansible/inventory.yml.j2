{#
  ansible/inventory.yml.j2 — Ansible static inventory for DataForge post-Terraform tasks.
  Defines: global product vars (product name, env, region, resource group) and
  optionally a databricks child group with the workspace host/token variables.
  Context vars: product_name, env, metadata (location, resource_group), has_databricks.
  Env logic: none — host values are expected to be populated from terraform output
  after apply (see inline comment in the file).
  Constraint: databricks_token must never be hardcoded; supply it via
  lookup("env", "DATABRICKS_TOKEN") or an encrypted vault file.
#}
# DataForge Ansible Inventory — {{ product_name }} ({{ env }})
# Generated by DataForge AnsibleGenerator (L7)
# Populate host values from terraform output after apply:
#   terraform output -json | python scripts/gen_inventory.py > ansible/inventory.yml
---
all:
  vars:
    dataforge_product: "{{ product_name }}"
    dataforge_env: "{{ env }}"
    azure_region: "{{ metadata.location }}"
    resource_group: "{{ metadata.resource_group }}"

{% if has_databricks %}
  children:
    databricks:
      hosts:
        databricks_workspace:
          # Populated by: terraform output databricks_workspace_url
          databricks_host: "{{ '{{ databricks_workspace_url }}' }}"
          databricks_token: "{{ '{{ lookup(\"env\", \"DATABRICKS_TOKEN\") }}' }}"
{% endif %}
