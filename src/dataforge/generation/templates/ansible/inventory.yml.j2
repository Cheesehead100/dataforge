# DataForge Ansible Inventory — {{ product_name }} ({{ env }})
# Generated by DataForge AnsibleGenerator (L7)
# Populate host values from terraform output after apply:
#   terraform output -json | python scripts/gen_inventory.py > ansible/inventory.yml
---
all:
  vars:
    dataforge_product: "{{ product_name }}"
    dataforge_env: "{{ env }}"
    azure_region: "{{ metadata.location }}"
    resource_group: "{{ metadata.resource_group }}"

{% if has_databricks %}
  children:
    databricks:
      hosts:
        databricks_workspace:
          # Populated by: terraform output databricks_workspace_url
          databricks_host: "{{ '{{ databricks_workspace_url }}' }}"
          databricks_token: "{{ '{{ lookup(\"env\", \"DATABRICKS_TOKEN\") }}' }}"
{% endif %}
