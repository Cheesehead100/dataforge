---
# DataForge Ansible Playbook — Configure Databricks
# Product: {{ product_name }} | Environment: {{ env }}
# Generated by DataForge AnsibleGenerator (L7)
#
# Prerequisites:
#   ansible-galaxy collection install -r ansible/requirements.yml
#
# Run after terraform apply:
#   export DATABRICKS_HOST=$(terraform output -raw databricks_workspace_url)
#   export DATABRICKS_TOKEN=<PAT or AAD token>
#   ansible-playbook -i ansible/inventory.yml ansible/playbooks/configure_databricks.yml

- name: "Configure Databricks Workspace — {{ product_name }}"
  hosts: localhost
  gather_facts: false
  vars:
    databricks_host: "{{ '{{ lookup(\"env\", \"DATABRICKS_HOST\") | regex_replace(\"/$\", \"\") }}' }}"
    databricks_token: "{{ '{{ lookup(\"env\", \"DATABRICKS_TOKEN\") }}' }}"
    product: "{{ product_name }}"
    env: "{{ env }}"
    api_headers:
      Authorization: "Bearer {{ '{{ databricks_token }}' }}"
      Content-Type: "application/json"

  pre_tasks:
    - name: "Assert required environment variables are set"
      assert:
        that:
          - databricks_host | length > 0
          - databricks_token | length > 0
        fail_msg: "DATABRICKS_HOST and DATABRICKS_TOKEN must be set"

  tasks:

    # ── Cluster Policy ────────────────────────────────────────────────────────
    - name: "Create cluster policy: {{ product_name }}-{{ env }}"
      uri:
        url: "{{ '{{ databricks_host }}' }}/api/2.0/policies/clusters/create"
        method: POST
        headers: "{{ '{{ api_headers }}' }}"
        body_format: json
        body:
          name: "{{ product_name }}-{{ env }}-policy"
          definition:
            spark_version:
              type: fixed
              value: "{{ runtime }}"
            node_type_id:
              type: fixed
              value: "{{ node_type }}"
            autoscale.min_workers:
              type: fixed
              value: "{{ min_workers }}"
            autoscale.max_workers:
              type: range
              maxValue: {{ max_workers }}
            autotermination_minutes:
              type: fixed
              value: 30
{% if spot_enabled %}
            azure_attributes.spot_bid_max_price:
              type: fixed
              value: "-1"
{% endif %}
        status_code: [200, 400]  # 400 = already exists
      register: cluster_policy_result

    - name: "Log cluster policy result"
      debug:
        msg: "Cluster policy: {{ '{{ cluster_policy_result.json.policy_id | default(\"already exists\") }}' }}"

{% if has_key_vault %}
    # ── Secret Scope (backed by Azure Key Vault) ──────────────────────────────
    - name: "Create Databricks secret scope: {{ product_name }}-{{ env }}"
      uri:
        url: "{{ '{{ databricks_host }}' }}/api/2.0/secrets/scopes/create"
        method: POST
        headers: "{{ '{{ api_headers }}' }}"
        body_format: json
        body:
          scope: "{{ product_name }}-{{ env }}"
          scope_backend_type: AZURE_KEYVAULT
          backend_azure_keyvault:
            resource_id: "{{ '{{ lookup(\"env\", \"KEY_VAULT_RESOURCE_ID\") }}' }}"
            dns_name: "{{ '{{ lookup(\"env\", \"KEY_VAULT_URI\") }}' }}"
          initial_manage_principal: users
        status_code: [200, 400]  # 400 = scope already exists
      register: secret_scope_result

    - name: "Log secret scope result"
      debug:
        msg: "Secret scope '{{ product_name }}-{{ env }}': {{ '{{ \"created\" if secret_scope_result.status == 200 else \"already exists\" }}' }}"
{% endif %}

{% if has_unity_catalog %}
    # ── Unity Catalog Bootstrap ───────────────────────────────────────────────
    - name: "Assign Unity Catalog metastore to workspace"
      uri:
        url: "{{ '{{ databricks_host }}' }}/api/2.1/unity-catalog/workspaces/{{ '{{ lookup(\"env\", \"DATABRICKS_WORKSPACE_ID\") }}' }}/metastore"
        method: PUT
        headers: "{{ '{{ api_headers }}' }}"
        body_format: json
        body:
          metastore_id: "{{ '{{ lookup(\"env\", \"UNITY_METASTORE_ID\") }}' }}"
          default_catalog_name: "{{ catalog }}"
        status_code: [200, 400]
      register: metastore_result

    - name: "Create Unity Catalog catalog: {{ catalog }}"
      uri:
        url: "{{ '{{ databricks_host }}' }}/api/2.1/unity-catalog/catalogs"
        method: POST
        headers: "{{ '{{ api_headers }}' }}"
        body_format: json
        body:
          name: "{{ catalog }}"
          comment: "{{ product_name }} — managed by DataForge"
        status_code: [200, 409]  # 409 = already exists
      register: catalog_result

{% for schema in schemas %}
    - name: "Create schema: {{ catalog }}.{{ schema }}"
      uri:
        url: "{{ '{{ databricks_host }}' }}/api/2.1/unity-catalog/schemas"
        method: POST
        headers: "{{ '{{ api_headers }}' }}"
        body_format: json
        body:
          name: "{{ schema }}"
          catalog_name: "{{ catalog }}"
          comment: "{{ schema }} layer — managed by DataForge"
        status_code: [200, 409]
{% endfor %}

{% endif %}

    # ── Upload Quality Check Scripts ──────────────────────────────────────────
    - name: "Ensure DBFS quality directory exists"
      uri:
        url: "{{ '{{ databricks_host }}' }}/api/2.0/dbfs/mkdirs"
        method: POST
        headers: "{{ '{{ api_headers }}' }}"
        body_format: json
        body:
          path: "dbfs:/dataforge/quality"
        status_code: [200]

    # ── Readiness Check ───────────────────────────────────────────────────────
    - name: "Verify workspace API is reachable"
      uri:
        url: "{{ '{{ databricks_host }}' }}/api/2.0/clusters/list"
        method: GET
        headers: "{{ '{{ api_headers }}' }}"
        status_code: [200]
      register: cluster_list
      retries: 5
      delay: 10
      until: cluster_list.status == 200

    - name: "Databricks configuration complete"
      debug:
        msg: "{{ product_name }} ({{ env }}) workspace configured successfully — {{ '{{ cluster_list.json.clusters | default([]) | length }}' }} clusters found"
