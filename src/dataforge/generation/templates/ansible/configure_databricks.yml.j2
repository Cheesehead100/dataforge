---
# DataForge Ansible Playbook — Configure Databricks
# Product: {{ product_name }} | Environment: {{ env }}
# Generated by DataForge AnsibleGenerator (L7)
# Run after: terraform apply
#   ansible-playbook -i ansible/inventory.yml ansible/playbooks/configure_databricks.yml

- name: "Configure Databricks Workspace — {{ product_name }}"
  hosts: localhost
  gather_facts: false
  vars:
    databricks_host: "{{ '{{ lookup(\"env\", \"DATABRICKS_HOST\") }}' }}"
    databricks_token: "{{ '{{ lookup(\"env\", \"DATABRICKS_TOKEN\") }}' }}"
    product: "{{ product_name }}"
    env: "{{ env }}"

  tasks:
    # ── Cluster Policy ────────────────────────────────────────────────────────
    - name: "Create cluster policy: {{ product_name }}-{{ env }}"
      community.databricks.databricks_cluster_policy:
        host: "{{ '{{ databricks_host }}' }}"
        token: "{{ '{{ databricks_token }}' }}"
        name: "{{ product_name }}-{{ env }}-policy"
        definition:
          spark_version:
            type: fixed
            value: "{{ runtime }}"
          node_type_id:
            type: fixed
            value: "{{ node_type }}"
          autoscale.min_workers:
            type: fixed
            value: {{ min_workers }}
          autoscale.max_workers:
            type: range
            maxValue: {{ max_workers }}
          autotermination_minutes:
            type: fixed
            value: 30
{% if spot_enabled %}
          aws_attributes.availability:
            type: fixed
            value: SPOT_WITH_FALLBACK
{% endif %}
      register: cluster_policy

    - name: "Log cluster policy ID"
      debug:
        msg: "Cluster policy created: {{ '{{ cluster_policy.policy_id | default(\"existing\") }}' }}"

{% if has_key_vault %}
    # ── Secret Scope (backed by Azure Key Vault) ──────────────────────────────
    - name: "Create Databricks secret scope: {{ product_name }}"
      community.databricks.databricks_secret_scope:
        host: "{{ '{{ databricks_host }}' }}"
        token: "{{ '{{ databricks_token }}' }}"
        name: "{{ product_name }}-{{ env }}"
        scope_backend_type: AZURE_KEYVAULT
        keyvault_metadata:
          resource_id: "{{ '{{ lookup(\"env\", \"KEY_VAULT_RESOURCE_ID\") }}' }}"
          dns_name: "{{ '{{ lookup(\"env\", \"KEY_VAULT_URI\") }}' }}"
      ignore_errors: true  # scope may already exist
{% endif %}

{% if has_unity_catalog %}
    # ── Unity Catalog Bootstrap ───────────────────────────────────────────────
    - name: "Assign Unity Catalog metastore to workspace"
      community.databricks.databricks_metastore_assignment:
        host: "{{ '{{ databricks_host }}' }}"
        token: "{{ '{{ databricks_token }}' }}"
        workspace_id: "{{ '{{ lookup(\"env\", \"DATABRICKS_WORKSPACE_ID\") }}' }}"
        metastore_id: "{{ '{{ lookup(\"env\", \"UNITY_METASTORE_ID\") }}' }}"
      ignore_errors: true  # may already be assigned

    - name: "Create Unity Catalog catalog: {{ catalog }}"
      community.databricks.databricks_catalog:
        host: "{{ '{{ databricks_host }}' }}"
        token: "{{ '{{ databricks_token }}' }}"
        name: "{{ catalog }}"
      register: uc_catalog

{% for schema in schemas %}
    - name: "Create schema: {{ catalog }}.{{ schema }}"
      community.databricks.databricks_schema:
        host: "{{ '{{ databricks_host }}' }}"
        token: "{{ '{{ databricks_token }}' }}"
        catalog_name: "{{ catalog }}"
        name: "{{ schema }}"
{% endfor %}

{% endif %}

    # ── Readiness Check ───────────────────────────────────────────────────────
    - name: "Verify workspace is operational"
      community.databricks.databricks_cluster_list:
        host: "{{ '{{ databricks_host }}' }}"
        token: "{{ '{{ databricks_token }}' }}"
      register: cluster_list
      retries: 5
      delay: 10
      until: cluster_list is succeeded

    - name: "Databricks configuration complete"
      debug:
        msg: "{{ product_name }} ({{ env }}) workspace configured successfully"
