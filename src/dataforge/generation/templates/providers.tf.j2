{#
  providers.tf.j2 — Terraform required_providers and provider configuration.
  Provisions: azurerm provider block; optional databricks and fabric providers.
  Context vars: databricks_nodes (list), fabric_nodes (list).
  Env logic: none — provider config is environment-agnostic.
  Constraint: databricks provider points at the first workspace only; multi-workspace
  stacks must add additional provider aliases manually.
#}
terraform {
  required_version = ">= 1.7"

  required_providers {
    azurerm = {
      source  = "hashicorp/azurerm"
      version = "~> 4.0"
    }
{% if databricks_nodes %}
    databricks = {
      source  = "databricks/databricks"
      version = "~> 1.52"
    }
{% endif %}
{% if fabric_nodes %}
    fabric = {
      source  = "microsoft/fabric"
      version = "~> 1.11"
    }
{% endif %}
  }
}

provider "azurerm" {
  resource_provider_registrations = "none"
  features {
    key_vault {
      purge_soft_delete_on_destroy    = false
      recover_soft_deleted_key_vaults = true
    }
    resource_group {
      prevent_deletion_if_contains_resources = false
    }
  }
}

{% if databricks_nodes %}
provider "databricks" {
  azure_workspace_resource_id = azurerm_databricks_workspace.{{ databricks_nodes[0].id }}.id
}
{% endif %}
