{% for node in fabric_nodes %}
# Microsoft Fabric Lakehouse
# Fabric resources are managed via the Microsoft Fabric admin portal or the
# microsoft/fabric Terraform provider (v1.11+). The capacity must already exist.

resource "fabric_workspace" "{{ node.id }}" {
  display_name = "${var.application_name}-${var.environment}"
  # capacity_id = var.fabric_capacity_id  # set this variable to your Fabric F-SKU capacity resource ID
}

resource "fabric_lakehouse" "{{ node.id }}" {
  workspace_id = fabric_workspace.{{ node.id }}.id
  display_name = "${var.application_name}-lakehouse-${var.environment}"
}

{% endfor %}
