{#
  databricks.tf.j2 — Azure Databricks workspace (Premium SKU) per Databricks node.
  Provisions: azurerm_databricks_workspace with no_public_ip=true and VNet injection
  into the subnets from networking.tf.
  Context vars: databricks_nodes.
  Env logic: none — workspace config is environment-agnostic; SKU/VNet params
  are fixed at Premium to support Unity Catalog.
  Constraint: networking.tf must be rendered first (databricks.tf depends_on the
  subnet NSG associations); Unity Catalog metastore assignment is commented out
  and requires a Databricks account admin to execute separately.
#}
{% for node in databricks_nodes %}
resource "azurerm_databricks_workspace" "{{ node.id }}" {
  name                = "dbw-${var.application_name}-${var.environment}"
  location            = var.location
  resource_group_name = var.resource_group_name
  sku                 = "premium"
  tags                = var.tags

  public_network_access_enabled         = false
  network_security_group_rules_required = "NoAzureDatabricksRules"

  custom_parameters {
    no_public_ip        = true
    virtual_network_id  = azurerm_virtual_network.dataforge.id
    private_subnet_name = azurerm_subnet.dbw_private.name
    public_subnet_name  = azurerm_subnet.dbw_public.name

    private_subnet_network_security_group_association_id = azurerm_subnet_network_security_group_association.dbw_private.id
    public_subnet_network_security_group_association_id  = azurerm_subnet_network_security_group_association.dbw_public.id
  }

  depends_on = [
    azurerm_subnet_network_security_group_association.dbw_private,
    azurerm_subnet_network_security_group_association.dbw_public,
  ]
}

# Unity Catalog metastore assignment (requires Databricks account admin)
# resource "databricks_metastore_assignment" "{{ node.id }}" {
#   metastore_id = var.databricks_metastore_id
#   workspace_id = azurerm_databricks_workspace.{{ node.id }}.workspace_id
# }

{% endfor %}
